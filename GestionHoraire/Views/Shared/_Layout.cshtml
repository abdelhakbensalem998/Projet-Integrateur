<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GestionHoraire</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GestionHoraire.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">GestionHoraire</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Accueil</a>
                        </li>
                        @if (Context.Session.GetInt32("UserId") != null)
                        {
                            var role = Context.Session.GetString("UserRole");
                            var userNom = Context.Session.GetString("UserNom");

                            if (role == "Administrateur")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-primary fw-bold" asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-speedometer2"></i> Admin</a>
                                </li>
                            }
                            else if (role == "ResponsableDépartement")
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-primary fw-bold" href="#" id="navbarDropdownResponsable" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-mortarboard-fill"></i> Ma Gestion
                                    </a>
                                    <ul class="dropdown-menu shadow border-0" aria-labelledby="navbarDropdownResponsable">
                                        <li><a class="dropdown-item" asp-controller="Responsable" asp-action="Index"><i class="bi bi-grid-fill me-2"></i>Tableau de bord</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Responsable" asp-action="Profs"><i class="bi bi-people-fill me-2"></i>Équipe Pédagogique</a></li>
                                        <li><a class="dropdown-item" asp-controller="Groupes" asp-action="Index"><i class="bi bi-mortarboard me-2"></i>Groupes d'études</a></li>
                                        <li><a class="dropdown-item" asp-controller="Affectations" asp-action="Index"><i class="bi bi-node-plus-fill me-2"></i>Affectations</a></li>
                                        <li><a class="dropdown-item" asp-controller="Planning" asp-action="Index"><i class="bi bi-calendar3 me-2"></i>Plannings</a></li>
                                        <li><a class="dropdown-item" asp-controller="Salles" asp-action="Index"><i class="bi bi-building-fill me-2"></i>Locaux / Labos</a></li>
                                        <li><a class="dropdown-item" asp-controller="Responsable" asp-action="Demandes"><i class="bi bi-chat-left-text-fill me-2"></i>Demandes</a></li>
                                    </ul>
                                </li>
                            }
                            else if (role == "Professeur")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-primary fw-bold" asp-controller="Professeur" asp-action="Index"><i class="bi bi-person-fill"></i> Mon Espace</a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Login" asp-action="Logout">Déconnexion (@userNom)</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold" asp-controller="Login" asp-action="Index">S'identifier</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - GestionHoraire - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
