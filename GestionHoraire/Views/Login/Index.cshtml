@{
    ViewData["Title"] = "Connexion";
}

<div class="login-page">
    <div class="login-wrapper">
        <div class="login-card">

            <!-- LEFT SIDE -->
            <div class="login-left">
                <h1>Gestion Horaire</h1>
                <p>
                    Plateforme intelligente de gestion des horaires académiques.
                </p>
                <ul>
                    <li>📅 Organisation des cours</li>
                    <li>👩‍🏫 Gestion des professeurs</li>
                    <li>🏢 Suivi par département</li>
                    <li>🔐 Accès sécurisé</li>
                </ul>
            </div>

            <!-- RIGHT SIDE -->
            <div class="login-right">
                <h3 class="text-center mb-4">Connexion</h3>

                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" placeholder="exemple@email.com" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mot de passe</label>
                        <input type="password" name="motDePasse" class="form-control" placeholder="••••••••" required />
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Error
                        </div>
                    }

                    <button type="submit" class="btn btn-primary w-100 mt-3">
                        Se connecter
                    </button>
                </form>

                <div class="mt-3 text-center">
                    <a asp-controller="Login" asp-action="ForgotPassword">Mot de passe oublié ?</a>
                </div>


            </div>

        </div>
    </div>
</div>

<style>
    .login-page {
        background: linear-gradient(135deg, #2563eb, #1e3a8a);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .login-wrapper {
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .login-card {
        display: flex;
        width: 900px;
        max-width: 100%;
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.25);
        animation: fadeIn 0.6s ease-in-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .login-left {
        flex: 1;
        padding: 40px;
        background: linear-gradient(160deg, #1e40af, #2563eb);
        color: white;
    }

    .login-left h1 {
        font-weight: 700;
        margin-bottom: 20px;
    }

    .login-left p {
        font-size: 16px;
        margin-bottom: 25px;
        opacity: 0.9;
    }

    .login-left ul {
        list-style: none;
        padding: 0;
    }

    .login-left li {
        margin-bottom: 10px;
        font-size: 15px;
    }

    .login-right {
        flex: 1;
        padding: 40px;
    }

    .login-right h3 {
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .login-card {
            flex-direction: column;
        }

        .login-left {
            text-align: center;
        }
    }
</style>
