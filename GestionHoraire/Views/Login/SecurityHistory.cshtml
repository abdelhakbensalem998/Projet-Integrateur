@model SecurityHistoryViewModel

@{
    ViewData["Title"] = "Historique de securite";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Historique de securite</h1>
            <p class="text-muted mb-0">
                Consultez les dernieres activites liees a votre compte.
            </p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="Login" asp-action="Manage2FA" class="btn btn-outline-primary">
                Securite du compte
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                Retour a l'accueil
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            @if (Model.Logs.Count == 0)
            {
                <div class="p-4">
                    <div class="alert alert-light border mb-0">
                        Aucune activite de securite pour le moment.
                    </div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Date</th>
                                <th scope="col">Action</th>
                                <th scope="col">Adresse IP</th>
                                <th scope="col">Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.Logs)
                            {
                                <tr>
                                    <td class="text-nowrap">
                                        @log.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                                    </td>
                                    <td>
                                        <div class="fw-semibold">@log.Label</div>
                                        <div class="text-muted small">@log.Action</div>
                                    </td>
                                    <td class="text-nowrap">
                                        @(string.IsNullOrWhiteSpace(log.IpAddress) ? "Inconnue" : log.IpAddress)
                                    </td>
                                    <td>
                                        @(string.IsNullOrWhiteSpace(log.Details) ? "-" : log.Details)
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
