@model VerifyTwoFactorViewModel

@{
    ViewData["Title"] = "Verification 2FA";
}

<style>
    .two-factor-page {
        min-height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        padding: 48px 16px;
        background: #f6f8fb;
    }

    .two-factor-shell {
        width: min(1040px, 100%);
        margin: 0 auto;
        display: grid;
        grid-template-columns: .95fr 1.05fr;
        overflow: hidden;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 18px 40px rgba(15, 23, 42, .12);
        animation: twoFactorIn .35s ease-out both;
    }

    .two-factor-context {
        min-height: 540px;
        padding: 48px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        color: #ffffff;
        background: linear-gradient(180deg, #0f766e 0%, #115e59 100%);
    }

    .security-kicker {
        display: inline-flex;
        width: fit-content;
        margin-bottom: 18px;
        padding: 8px 12px;
        border: 1px solid rgba(255, 255, 255, .32);
        border-radius: 8px;
        color: #dffcf7;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0;
        text-transform: uppercase;
    }

    .two-factor-context h1 {
        margin: 0;
        color: #ffffff;
        font-size: 42px;
        font-weight: 800;
        line-height: 1.1;
    }

    .two-factor-context p {
        margin: 18px 0 0;
        max-width: 440px;
        color: rgba(255, 255, 255, .88);
        font-size: 17px;
        line-height: 1.6;
    }

    .security-steps {
        margin: 42px 0 0;
        padding: 0;
        list-style: none;
        border-top: 1px solid rgba(255, 255, 255, .22);
    }

    .security-steps li {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 16px 0;
        border-bottom: 1px solid rgba(255, 255, 255, .22);
        color: rgba(255, 255, 255, .92);
        font-weight: 600;
    }

    .security-steps span {
        width: 34px;
        height: 34px;
        display: grid;
        place-items: center;
        flex: 0 0 auto;
        border-radius: 8px;
        background: rgba(255, 255, 255, .16);
        color: #ffffff;
        font-size: 13px;
        font-weight: 800;
    }

    .two-factor-form-panel {
        padding: 52px;
        display: flex;
        align-items: center;
    }

    .two-factor-form {
        width: 100%;
        max-width: 480px;
        margin: 0 auto;
    }

    .provider-pill {
        display: inline-flex;
        align-items: center;
        margin-bottom: 18px;
        padding: 8px 12px;
        border-radius: 8px;
        background: #ecfeff;
        color: #155e75;
        font-size: 13px;
        font-weight: 800;
    }

    .two-factor-form h2 {
        margin: 0;
        color: #111827;
        font-size: 34px;
        font-weight: 800;
        line-height: 1.15;
    }

    .form-hint {
        margin: 12px 0 26px;
        color: #4b5563;
        line-height: 1.6;
    }

    .two-factor-message {
        margin-bottom: 16px;
        padding: 12px 14px;
        border-radius: 8px;
        font-weight: 700;
    }

    .two-factor-message.error {
        border: 1px solid #fecdd3;
        background: #fff1f2;
        color: #9f1239;
    }

    .two-factor-message.success {
        border: 1px solid #bbf7d0;
        background: #f0fdf4;
        color: #166534;
    }

    .two-factor-message.info {
        border: 1px solid #bae6fd;
        background: #f0f9ff;
        color: #075985;
    }

    .code-field {
        margin-bottom: 18px;
    }

    .code-field label {
        display: block;
        margin-bottom: 8px;
        color: #111827;
        font-weight: 800;
    }

    .code-input {
        width: 100%;
        min-height: 58px;
        padding: 14px 16px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        outline: none;
        color: #111827;
        background: #ffffff;
        font-size: 24px;
        font-weight: 800;
        text-align: center;
        letter-spacing: 0;
        transition: border-color .16s ease, box-shadow .16s ease, transform .16s ease;
    }

    .code-input:focus {
        border-color: #0f766e;
        box-shadow: 0 0 0 4px rgba(15, 118, 110, .14);
        transform: translateY(-1px);
    }

    .code-help {
        display: block;
        margin-top: 8px;
        color: #6b7280;
        font-size: 13px;
    }

    .remember-device {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        margin: 22px 0;
        color: #374151;
    }

    .remember-device input {
        margin-top: 4px;
    }

    .primary-action,
    .secondary-action {
        width: 100%;
        min-height: 48px;
        border-radius: 8px;
        font-weight: 800;
        transition: transform .16s ease, box-shadow .16s ease, background-color .16s ease;
    }

    .primary-action:hover,
    .secondary-action:hover {
        transform: translateY(-1px);
    }

    .primary-action {
        border: 0;
        background: #0f766e;
        color: #ffffff;
    }

    .primary-action:hover {
        background: #0d665f;
        box-shadow: 0 12px 24px rgba(15, 118, 110, .22);
    }

    .secondary-action {
        margin-top: 12px;
        border: 1px solid #0f766e;
        background: #ffffff;
        color: #0f766e;
    }

    .secondary-action:hover {
        background: #f0fdfa;
    }

    .back-link {
        display: inline-flex;
        margin-top: 20px;
        color: #155e75;
        font-weight: 800;
        text-decoration: none;
    }

    .back-link:hover {
        color: #0f766e;
        text-decoration: underline;
    }

    @@keyframes twoFactorIn {
        from {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 860px) {
        .two-factor-page {
            padding: 24px 12px;
        }

        .two-factor-shell {
            grid-template-columns: 1fr;
        }

        .two-factor-context {
            min-height: auto;
            padding: 32px 24px;
        }

        .two-factor-context h1 {
            font-size: 34px;
        }

        .security-steps {
            margin-top: 28px;
        }

        .two-factor-form-panel {
            padding: 34px 24px;
        }

        .two-factor-form h2 {
            font-size: 30px;
        }
    }
</style>

<div class="two-factor-page">
    <div class="two-factor-shell">
        <section class="two-factor-context" aria-label="Connexion securisee">
            <div>
                <span class="security-kicker">Connexion securisee</span>
                <h1>Confirmez votre identite</h1>
                <p>
                    Cette etape protege votre compte avant d'ouvrir la session.
                </p>
            </div>

            <ul class="security-steps" aria-label="Etapes de protection">
                <li><span>01</span> Code temporaire</li>
                <li><span>02</span> Verification rapide</li>
                <li><span>03</span> Session protegee</li>
            </ul>
        </section>

        <section class="two-factor-form-panel">
            <div class="two-factor-form">
                <div class="provider-pill">@Model.ProviderLabel</div>
                <h2>Verification 2FA</h2>
                <p class="form-hint">@Model.Instruction</p>

                @if (TempData["Error"] != null)
                {
                    <div class="two-factor-message error">
                        @TempData["Error"]
                    </div>
                }

                @if (TempData["Success"] != null)
                {
                    <div class="two-factor-message success">
                        @TempData["Success"]
                    </div>
                }

                @if (TempData["Info"] != null)
                {
                    <div class="two-factor-message info">
                        @TempData["Info"]
                    </div>
                }

                @if (ViewBag.Error != null)
                {
                    <div class="two-factor-message error">
                        @ViewBag.Error
                    </div>
                }

                <form asp-action="Verify2FA" method="post">
                    @Html.AntiForgeryToken()

                    <div class="code-field">
                        <label for="verificationCode">@Model.InputLabel</label>
                        <input type="text"
                               id="verificationCode"
                               name="verificationCode"
                               class="code-input"
                               placeholder="123456"
                               autocomplete="one-time-code"
                               spellcheck="false"
                               autofocus
                               required />
                        <small class="code-help">Saisissez le code exactement comme vous le voyez.</small>
                    </div>

                    <div class="remember-device">
                        <input class="form-check-input" type="checkbox" id="rememberDevice" name="rememberDevice" value="true" />
                        <label for="rememberDevice">
                            Memoriser cet appareil pendant 30 jours.
                        </label>
                    </div>

                    <button type="submit" class="primary-action">
                        Continuer
                    </button>
                </form>

                @if (Model.AllowResend)
                {
                    <form asp-action="Resend2FA" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="secondary-action">
                            Renvoyer le code
                        </button>
                    </form>
                }

                <a asp-action="Index" class="back-link">Retour a la connexion</a>
            </div>
        </section>
    </div>
</div>

<script>
    (() => {
        const codeInput = document.getElementById("verificationCode");

        if (!codeInput) {
            return;
        }

        codeInput.addEventListener("input", () => {
            codeInput.value = codeInput.value.replace(/\s+/g, "").toUpperCase();
        });
    })();
</script>
