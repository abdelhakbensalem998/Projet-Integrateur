@{
    ViewData["Title"] = "Vérification 2FA";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-primary text-white text-center p-4">
                    <div style="font-size: 2.2rem;">🛡️</div>
                    <h2 class="fw-bold mb-1">Vérification 2FA</h2>
                    <p class="mb-0 opacity-75">
                        Entrez le code reçu par email pour continuer.
                    </p>
                </div>

                <div class="card-body p-4 p-md-5">

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger rounded-3">
                            @TempData["Error"]
                        </div>
                    }

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success rounded-3">
                            @TempData["Success"]
                        </div>
                    }

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger rounded-3">
                            @ViewBag.Error
                        </div>
                    }

                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success rounded-3">
                            @ViewBag.Success
                        </div>
                    }

                    <form asp-action="Verify2FA" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            <label for="codeEmail" class="form-label fw-semibold">
                                Code de vérification
                            </label>
                            <input type="text"
                                   id="codeEmail"
                                   name="codeEmail"
                                   class="form-control form-control-lg rounded-3 text-center"
                                   placeholder="Entrez le code"
                                   required />
                        </div>

                        <div class="form-check mb-4">
                            <input class="form-check-input" type="checkbox" id="rememberDevice" name="rememberDevice" value="true" />
                            <label class="form-check-label" for="rememberDevice">
                                Mémoriser cet appareil pendant 30 jours
                            </label>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mb-3">
                            Valider
                        </button>
                    </form>

                    <form asp-action="Resend2FA" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-primary w-100 mb-3">
                            Renvoyer le code
                        </button>
                    </form>

                    <div class="text-center">
                        <a asp-action="Index" class="text-decoration-none">← Retour</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>