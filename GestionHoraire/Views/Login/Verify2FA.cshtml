@model GestionHoraire.Models.ViewModels.VerifyTwoFactorViewModel

@{
    ViewData["Title"] = "Vérification 2FA";
}

<style>
    .two-factor-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .glass-login-card {
        background: white;
        border-radius: 24px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.1);
        overflow: hidden;
        width: 100%;
        max-width: 450px;
        border: 1px solid rgba(0,0,0,0.05);
    }

    .card-header-premium {
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        padding: 40px 30px;
        text-align: center;
        color: white;
    }

    .card-body-premium {
        padding: 40px;
    }

    .code-input-premium {
        font-size: 1.5rem;
        letter-spacing: 0.5rem;
        text-align: center;
        font-weight: 700;
        border-radius: 12px;
        border: 2px solid #e2e8f0;
        padding: 15px;
        transition: all 0.3s ease;
    }

    .code-input-premium:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        outline: none;
    }

    .btn-premium-action {
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border: none;
        color: white;
        padding: 12px;
        border-radius: 12px;
        font-weight: 600;
        width: 100%;
        transition: transform 0.2s;
    }

    .btn-premium-action:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(79, 70, 229, 0.2);
    }
</style>

<div class="two-factor-container">
    <div class="glass-login-card animate__animated animate__fadeIn">
        <div class="card-header-premium">
            <div class="mb-3 d-inline-flex bg-white bg-opacity-20 rounded-circle p-3">
                <i class="bi bi-shield-lock-fill fs-2"></i>
            </div>
            <h3 class="fw-bold mb-1">Vérification</h3>
            <p class="mb-0 opacity-75 small">Double authentification requise</p>
        </div>

        <div class="card-body-premium">
            <div class="text-center mb-4">
                <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill mb-3">
                    @Model.ProviderLabel
                </span>
                <p class="text-muted small">
                    @Model.Instruction
                </p>
            </div>

            @if (TempData["Error"] != null || ViewBag.Error != null)
            {
                <div class="alert alert-danger border-0 rounded-3 small mb-4">
                    <i class="bi bi-exclamation-circle me-2"></i> @(TempData["Error"] ?? ViewBag.Error)
                </div>
            }

            <form asp-action="Verify2FA" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-4">
                    <label for="verificationCode" class="form-label fw-semibold small text-uppercase">@Model.InputLabel</label>
                    <input type="text"
                           id="verificationCode"
                           name="verificationCode"
                           class="form-control code-input-premium"
                           placeholder="000000"
                           maxlength="10"
                           required
                           autofocus />
                    <div class="form-text text-center mt-2">
                        Saisissez le code à 6 chiffres
                    </div>
                </div>

                <div class="form-check mb-4">
                    <input class="form-check-input" type="checkbox" id="rememberDevice" name="rememberDevice" value="true" checked />
                    <label class="form-check-label small" for="rememberDevice">
                        Mémoriser cet appareil pendant 30 jours
                    </label>
                </div>

                <button type="submit" class="btn btn-premium-action btn-lg mb-3">
                    Confirmer <i class="bi bi-arrow-right ms-2"></i>
                </button>
            </form>

            @if (Model.AllowResend)
            {
                <form asp-action="Resend2FA" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-link w-100 text-decoration-none text-muted small">
                        Renvoyer le code par email
                    </button>
                </form>
            }

            <div class="mt-4 text-center border-top pt-3">
                <a asp-action="Index" class="text-decoration-none text-muted small">
                    <i class="bi bi-arrow-left me-1"></i> Retour à la connexion
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById("verificationCode").addEventListener("input", function(e) {
        this.value = this.value.replace(/[^0-9A-Z]/gi, '').toUpperCase();
    });
</script>
