@using Microsoft.AspNetCore.Http
@using GestionHoraire.Data
@inject AppDbContext Db

@{
    ViewData["Title"] = "Accueil";

    var userId = Context.Session.GetInt32("UserId");
    var role = Context.Session.GetString("UserRole");
    var userNom = Context.Session.GetString("UserNom");

    bool twoFactorEnabled = false;
    bool authenticatorConfigured = false;
    string twoFactorLabel = "2FA desactive";

    if (userId != null)
    {
        var currentUser = Db.Utilisateurs.FirstOrDefault(u => u.Id == userId.Value);
        if (currentUser != null)
        {
            twoFactorEnabled = currentUser.TwoFactorEnabled;
            authenticatorConfigured = currentUser.TwoFactorEnabled &&
                currentUser.TwoFactorProvider == "Authenticator" &&
                !string.IsNullOrWhiteSpace(currentUser.AuthenticatorSecretKey);

            twoFactorLabel = authenticatorConfigured
                ? "Authenticator active"
                : twoFactorEnabled
                    ? "2FA email active"
                    : "2FA desactive";
        }
    }

    string dashboardController = role switch
    {
        "Administrateur" => "Admin",
        "ResponsableDépartement" => "Responsable",
        "Professeur" => "Professeur",
        _ => "Home"
    };

    string roleLabel = role switch
    {
        "Administrateur" => "Administrateur",
        "ResponsableDépartement" => "Responsable de departement",
        "Professeur" => "Professeur",
        _ => "Invite"
    };

    string dashboardText = role switch
    {
        "Administrateur" => "Pilotez les utilisateurs, les salles, les groupes et les departements.",
        "ResponsableDépartement" => "Suivez les professeurs, les groupes, le planning et les affectations.",
        "Professeur" => "Consultez votre espace professeur et vos informations principales.",
        _ => "Accedez a votre espace de travail."
    };
}

<div class="app-page">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
    }

    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show mb-4" role="alert">
            @TempData["Info"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
    }

    <section class="app-hero">
        <div class="app-hero-grid">
            <div>
                <span class="app-kicker">Gestion Horaire</span>
                <h1 class="app-title">
                    @if (userId != null)
                    {
                        <text>Bonjour, @userNom</text>
                    }
                    else
                    {
                        <text>Bienvenue sur la plateforme</text>
                    }
                </h1>
                <p class="app-subtitle">
                    Un espace central pour organiser les cours, les salles, les groupes, les affectations et la securite du compte.
                </p>

                <div class="app-pills">
                    @if (userId != null)
                    {
                        <span class="app-pill primary">@roleLabel</span>
                        <span class="app-pill @(twoFactorEnabled ? "success" : "muted")">@twoFactorLabel</span>
                        <span class="app-pill muted">Session ouverte</span>
                    }
                    else
                    {
                        <span class="app-pill primary">Acces securise</span>
                        <span class="app-pill muted">Connexion requise</span>
                    }
                </div>
            </div>

            <aside class="app-status-panel">
                <h2>Etat rapide</h2>
                <div class="app-status-list">
                    <div class="app-status-row">
                        <span class="app-label">Utilisateur</span>
                        <span class="app-value">@(userId != null ? userNom : "Non connecte")</span>
                    </div>
                    <div class="app-status-row">
                        <span class="app-label">Role</span>
                        <span class="app-value">@roleLabel</span>
                    </div>
                    <div class="app-status-row">
                        <span class="app-label">Securite</span>
                        <span class="app-value">@twoFactorLabel</span>
                    </div>
                </div>
            </aside>
        </div>
    </section>

    @if (userId != null)
    {
        <section class="app-section">
            <div class="app-section-title">
                <div>
                    <h2>Actions principales</h2>
                    <p>Les raccourcis utiles sont separes pour que chaque action soit claire.</p>
                </div>
            </div>

            <div class="app-action-grid">
                <a class="app-action-card primary"
                   asp-controller="@dashboardController"
                   asp-action="Index">
                    <div>
                        <div class="app-action-eyebrow">Travail</div>
                        <div class="app-action-title">Tableau de bord</div>
                        <div class="app-action-text">@dashboardText</div>
                    </div>
                    <div class="app-action-arrow">Ouvrir</div>
                </a>

                <a class="app-action-card"
                   asp-controller="Login"
                   asp-action="Manage2FA">
                    <div>
                        <div class="app-action-eyebrow">Compte</div>
                        <div class="app-action-title">Securite</div>
                        <div class="app-action-text">Choisissez l'email, l'Authenticator, les codes de secours et les appareils memorises.</div>
                    </div>
                    <div class="app-action-arrow">Gerer</div>
                </a>

                <a class="app-action-card"
                   asp-controller="Login"
                   asp-action="SecurityHistory">
                    <div>
                        <div class="app-action-eyebrow">Suivi</div>
                        <div class="app-action-title">Historique</div>
                        <div class="app-action-text">Consultez les connexions, les echecs 2FA et les changements sensibles.</div>
                    </div>
                    <div class="app-action-arrow">Voir</div>
                </a>

                <a class="app-action-card danger"
                   asp-controller="Login"
                   asp-action="Logout">
                    <div>
                        <div class="app-action-eyebrow">Session</div>
                        <div class="app-action-title">Deconnexion</div>
                        <div class="app-action-text">Fermez proprement la session avant de quitter l'ordinateur.</div>
                    </div>
                    <div class="app-action-arrow">Quitter</div>
                </a>
            </div>
        </section>

        <section class="app-section">
            <div class="app-section-title">
                <div>
                    <h2>Acces metier</h2>
                    <p>Les pages disponibles suivent votre role actuel.</p>
                </div>
            </div>

            <div class="app-action-grid">
                @if (role == "Administrateur")
                {
                    <a class="app-action-card" asp-controller="Admin" asp-action="Utilisateurs">
                        <div>
                            <div class="app-action-eyebrow">Admin</div>
                            <div class="app-action-title">Utilisateurs</div>
                            <div class="app-action-text">Creer, modifier, filtrer et supprimer les comptes.</div>
                        </div>
                        <div class="app-action-arrow">Ouvrir</div>
                    </a>

                    <a class="app-action-card" asp-controller="Departements" asp-action="Index">
                        <div>
                            <div class="app-action-eyebrow">Structure</div>
                            <div class="app-action-title">Departements</div>
                            <div class="app-action-text">Gerez les departements de la plateforme.</div>
                        </div>
                        <div class="app-action-arrow">Ouvrir</div>
                    </a>

                    <a class="app-action-card" asp-controller="Salles" asp-action="Index">
                        <div>
                            <div class="app-action-eyebrow">Ressources</div>
                            <div class="app-action-title">Salles</div>
                            <div class="app-action-text">Consultez et organisez les salles disponibles.</div>
                        </div>
                        <div class="app-action-arrow">Ouvrir</div>
                    </a>

                    <a class="app-action-card" asp-controller="Groupes" asp-action="Index">
                        <div>
                            <div class="app-action-eyebrow">Classes</div>
                            <div class="app-action-title">Groupes</div>
                            <div class="app-action-text">Suivez les groupes rattaches aux departements.</div>
                        </div>
                        <div class="app-action-arrow">Ouvrir</div>
                    </a>
                }
                else if (role == "ResponsableDépartement")
                {
                    <a class="app-action-card" asp-controller="Responsable" asp-action="Profs">
                        <div>
                            <div class="app-action-eyebrow">Equipe</div>
                            <div class="app-action-title">Professeurs</div>
                            <div class="app-action-text">Consultez et gerez les professeurs du departement.</div>
                        </div>
                        <div class="app-action-arrow">Ouvrir</div>
                    </a>

                    <a class="app-action-card" asp-controller="Groupes" asp-action="Index">
                        <div>
                            <div class="app-action-eyebrow">Classes</div>
                            <div class="app-action-title">Groupes</div>
                            <div class="app-action-text">Organisez les groupes et leurs informations.</div>
                        </div>
                        <div class="app-action-arrow">Ouvrir</div>
                    </a>

                    <a class="app-action-card" asp-controller="Planning" asp-action="Index">
                        <div>
                            <div class="app-action-eyebrow">Planning</div>
                            <div class="app-action-title">Emploi du temps</div>
                            <div class="app-action-text">Visualisez les horaires et les disponibilites.</div>
                        </div>
                        <div class="app-action-arrow">Ouvrir</div>
                    </a>

                    <a class="app-action-card" asp-controller="Affectations" asp-action="Index">
                        <div>
                            <div class="app-action-eyebrow">Cours</div>
                            <div class="app-action-title">Affectations</div>
                            <div class="app-action-text">Associez les cours aux professeurs et aux salles.</div>
                        </div>
                        <div class="app-action-arrow">Ouvrir</div>
                    </a>
                }
                else
                {
                    <a class="app-action-card" asp-controller="Professeur" asp-action="Index">
                        <div>
                            <div class="app-action-eyebrow">Espace</div>
                            <div class="app-action-title">Mes cours</div>
                            <div class="app-action-text">Accedez a votre espace professeur.</div>
                        </div>
                        <div class="app-action-arrow">Ouvrir</div>
                    </a>
                }
            </div>
        </section>
    }
    else
    {
        <section class="app-section">
            <div class="app-action-grid">
                <a class="app-action-card primary" asp-controller="Login" asp-action="Index">
                    <div>
                        <div class="app-action-eyebrow">Connexion</div>
                        <div class="app-action-title">Se connecter</div>
                        <div class="app-action-text">Ouvrez votre espace avec votre compte Gestion Horaire.</div>
                    </div>
                    <div class="app-action-arrow">Commencer</div>
                </a>

                <a class="app-action-card" asp-controller="Home" asp-action="Privacy">
                    <div>
                        <div class="app-action-eyebrow">Information</div>
                        <div class="app-action-title">Confidentialite</div>
                        <div class="app-action-text">Consultez les informations liees a l'utilisation de l'application.</div>
                    </div>
                    <div class="app-action-arrow">Lire</div>
                </a>
            </div>
        </section>
    }

    <section class="app-section">
        <div class="app-section-title">
            <div>
                <h2>Ce que la plateforme centralise</h2>
                <p>Une vue simple sur les elements importants de la gestion horaire.</p>
            </div>
        </div>

        <div class="app-stat-grid">
            <div class="app-stat-card">
                <h3>Cours et affectations</h3>
                <p>Regroupez les cours, les professeurs, les salles et les groupes dans un seul flux.</p>
            </div>

            <div class="app-stat-card">
                <h3>Disponibilites</h3>
                <p>Suivez les creneaux utiles pour organiser le planning avec moins d'ambiguite.</p>
            </div>

            <div class="app-stat-card">
                <h3>Securite du compte</h3>
                <p>Activez la 2FA, verifiez les appareils de confiance et consultez l'historique.</p>
            </div>
        </div>
    </section>
</div>
