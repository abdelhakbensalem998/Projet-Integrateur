@using Microsoft.AspNetCore.Http
@using GestionHoraire.Data
@inject AppDbContext Db

@{
    ViewData["Title"] = "Accueil";

    var userId = Context.Session.GetInt32("UserId");
    var role = Context.Session.GetString("UserRole");
    var userNom = Context.Session.GetString("UserNom");

    bool twoFactorEnabled = false;

    if (userId != null)
    {
        var currentUser = Db.Utilisateurs.FirstOrDefault(u => u.Id == userId.Value);
        if (currentUser != null)
        {
            twoFactorEnabled = currentUser.TwoFactorEnabled;
        }
    }

    string dashboardController = role switch
    {
        "Administrateur" => "Admin",
        "ResponsableDépartement" => "Responsable",
        "Professeur" => "Professeur",
        _ => "Home"
    };
}

<div class="container py-5">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm mb-4" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
    }

    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show rounded-4 shadow-sm mb-4" role="alert">
            @TempData["Info"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm mb-4" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
    }

    <div class="p-4 p-md-5 mb-5 bg-white rounded-4 shadow-sm border">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <span class="badge bg-primary-subtle text-primary mb-3 px-3 py-2 rounded-pill">
                    Plateforme académique
                </span>

                <h1 class="fw-bold mb-3" style="font-size:2.5rem;">Gestion Horaire</h1>

                <p class="text-muted fs-5 mb-4">
                    Plateforme de gestion des cours, affectations, salles et disponibilités des professeurs.
                </p>

                @if (userId != null)
                {
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-4">
                        <span class="badge bg-success px-3 py-2 rounded-pill">Connectée</span>
                        <span class="text-secondary">
                            Bonjour, <strong>@userNom</strong> <span class="text-muted">(@role)</span>
                        </span>

                        @if (twoFactorEnabled)
                        {
                            <span class="badge bg-primary px-3 py-2 rounded-pill">
                                2FA activé
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary px-3 py-2 rounded-pill">
                                2FA désactivé
                            </span>
                        }
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-primary px-4"
                           asp-controller="@dashboardController"
                           asp-action="Index">
                            Continuer vers mon tableau de bord
                        </a>

                        <form asp-controller="Login" asp-action="Toggle2FA" method="post" class="d-inline">
                            @Html.AntiForgeryToken()

                            @if (twoFactorEnabled)
                            {
                                <button type="submit" class="btn btn-outline-danger px-4">
                                    Désactiver le 2FA
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-outline-primary px-4">
                                    Activer le 2FA
                                </button>
                            }
                        </form>

                        <a class="btn btn-outline-secondary px-4"
                           asp-controller="Login"
                           asp-action="Logout">
                            Se déconnecter
                        </a>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-primary btn-lg px-4"
                           asp-controller="Login"
                           asp-action="Index">
                            Se connecter
                        </a>

                        <a class="btn btn-outline-secondary btn-lg px-4"
                           asp-controller="Home"
                           asp-action="Privacy">
                            Politique de confidentialité
                        </a>
                    </div>
                }
            </div>

            <div class="col-lg-5">
                <div class="rounded-4 border bg-light p-4 h-100">
                    <h5 class="fw-bold mb-3">Espace sécurisé</h5>
                    <p class="text-muted mb-3">
                        Accès selon le rôle, gestion des disponibilités, sécurité de connexion et suivi des actions sensibles.
                    </p>

                    <div class="d-flex flex-column gap-2">
                        <div class="bg-white border rounded-3 px-3 py-2">Connexion sécurisée</div>
                        <div class="bg-white border rounded-3 px-3 py-2">Réinitialisation du mot de passe</div>
                        <div class="bg-white border rounded-3 px-3 py-2">Authentification à deux facteurs</div>
                        <div class="bg-white border rounded-3 px-3 py-2">Gestion par rôle</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="mb-3 fs-3">📚</div>
                    <h5 class="card-title fw-bold">Gestion des cours</h5>
                    <p class="card-text text-muted mb-0">
                        Centraliser la liste des cours et associer professeur et salle de manière simple.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="mb-3 fs-3">🗓️</div>
                    <h5 class="card-title fw-bold">Disponibilités</h5>
                    <p class="card-text text-muted mb-0">
                        Visualiser et mettre à jour les créneaux de disponibilité des professeurs.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="mb-3 fs-3">🏢</div>
                    <h5 class="card-title fw-bold">Par département</h5>
                    <p class="card-text text-muted mb-0">
                        Organisation adaptée selon les rôles : administrateur, responsable et professeur.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div>
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
            <h2 class="h4 fw-bold mb-0">Accès selon votre rôle</h2>
            <span class="text-muted small">Navigation adaptée à chaque utilisateur</span>
        </div>

        <div class="row g-3">
            <div class="col-lg-4">
                <div class="border rounded-4 p-4 h-100 bg-white shadow-sm">
                    <div class="fw-bold mb-2 fs-5">👑 Administrateur</div>
                    <div class="text-muted">
                        Gestion globale des utilisateurs, structures et paramètres.
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="border rounded-4 p-4 h-100 bg-white shadow-sm">
                    <div class="fw-bold mb-2 fs-5">🧑‍💼 Responsable de département</div>
                    <div class="text-muted">
                        Affectation prof/salle, suivi des cours et gestion des disponibilités.
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="border rounded-4 p-4 h-100 bg-white shadow-sm">
                    <div class="fw-bold mb-2 fs-5">👩‍🏫 Professeur</div>
                    <div class="text-muted">
                        Accès à ses informations, ses disponibilités et ses cours.
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>