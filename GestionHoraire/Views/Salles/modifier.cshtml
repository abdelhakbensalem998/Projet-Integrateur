@model GestionHoraire.Models.Salle

@{
    ViewData["Title"] = "Modifier la Salle";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    body {
        background: #f8fafc;
        font-family: 'Outfit', sans-serif;
    }

    .premium-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(12px);
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
    }

    .card-header-gradient {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        color: white;
        border-radius: 24px 24px 0 0 !important;
        padding: 1.5rem;
    }

    .form-control, .form-select {
        border-radius: 12px;
        padding: 12px 20px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        font-family: 'Outfit', sans-serif;
    }

    .form-control:focus, .form-select:focus {
        box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        border-color: #4f46e5;
        background: white;
    }

    .btn-premium {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px;
        font-weight: 600;
        font-family: 'Outfit', sans-serif;
        transition: all 0.3s;
    }

    .btn-premium:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(79, 70, 229, 0.2);
        color: white;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Infrastructures</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Modifier @Model?.Nom</li>
                </ol>
            </nav>

            <div class="premium-card overflow-hidden">
                <div class="card-header-gradient text-center">
                    <h3 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Modifier la salle</h3>
                </div>
                <div class="card-body p-4 p-lg-5">
                    <form asp-action="Modifier" method="post">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="mb-4">
                            <label asp-for="Nom" class="form-label fw-bold text-muted small text-uppercase">Nom de la salle</label>
                            <input asp-for="Nom" class="form-control" required />
                            <span asp-validation-for="Nom" class="text-danger small mt-1"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="Capacite" class="form-label fw-bold text-muted small text-uppercase">Capacité (places)</label>
                            <input asp-for="Capacite" type="number" class="form-control" required min="1" />
                            <span asp-validation-for="Capacite" class="text-danger small mt-1"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="Type" class="form-label fw-bold text-muted small text-uppercase">Type d'usage</label>
                            <select asp-for="Type" class="form-select" required>
                                <option value="Cours">Salle de Cours</option>
                                <option value="Labo">Laboratoire</option>
                                <option value="Amphi">Amphithéâtre</option>
                                <option value="TP">Salle Informatique</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger small mt-1"></span>
                        </div>
                        
                        <div class="d-grid gap-3 mt-5">
                            <button type="submit" class="btn btn-premium">
                                <i class="bi bi-save me-2"></i>Enregistrer les modifications
                            </button>
                            <a asp-action="Index" class="btn btn-light rounded-3 py-2 fw-bold text-center">
                                <i class="bi bi-arrow-left me-2"></i>Annuler
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}