@model IEnumerable<GestionHoraire.Models.Salle>
@using Microsoft.AspNetCore.Http

@{
    bool isAdmin = Context.Session.GetString("UserRole") == "Administrateur";
    string retourController = isAdmin ? "Admin" : "Responsable";
    string retourAction = isAdmin ? "Dashboard" : "Index";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h2 class="fw-bold"><i class="bi bi-door-open-fill me-2 text-primary"></i>Infrastructures</h2>
        <a asp-action="Ajouter" class="btn btn-success shadow-sm rounded-pill px-4">
            <i class="bi bi-plus-lg"></i> Ajouter
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
    }

    <div class="row">
        @foreach (var salle in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0 border-top border-4 border-primary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <h5 class="fw-bold">@salle.Nom</h5>
                            <span class="badge bg-info text-dark rounded-pill">@salle.Capacite places</span>
                        </div>
                        <p class="text-muted mt-2 small text-uppercase">Type : @salle.Type</p>
                    </div>
                    <div class="card-footer bg-transparent border-0 d-flex justify-content-end gap-2 pb-3">
                        <a asp-action="Modifier" asp-route-id="@salle.Id" class="btn btn-sm btn-outline-warning">Modifier</a>
                        <form asp-action="Supprimer" method="post" onsubmit="return confirm('Supprimer ?');">
                            <input type="hidden" name="id" value="@salle.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
    <a asp-controller="@retourController" asp-action="@retourAction" class="btn btn-secondary mt-3">Retour Dashboard</a>
</div>
