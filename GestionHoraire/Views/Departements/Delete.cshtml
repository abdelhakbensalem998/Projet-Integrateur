@model GestionHoraire.Models.Departement

@{
    ViewData["Title"] = "Supprimer le Département";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-danger text-white py-3 text-center fw-bold rounded-top-4">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirmation de Suppression
                </div>
                <div class="card-body p-4 text-center">
                    <h5 class="text-dark mb-4">Êtes-vous sûr de vouloir supprimer ce département ?</h5>
                    
                    <div class="alert alert-warning text-start mb-4">
                        <strong>Attention :</strong> La suppression d'un département peut affecter les utilisateurs et les groupes qui y sont rattachés.
                    </div>

                    <div class="mb-4">
                        <h4 class="fw-bold text-danger">@Model.Nom</h4>
                    </div>

                    <form asp-action="Delete" method="post" class="d-grid gap-2">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger fw-bold shadow-sm">
                            <i class="bi bi-trash-fill me-2"></i>Oui, supprimer définitivement
                        </button>
                        <a asp-action="Index" class="btn btn-light shadow-sm">
                            <i class="bi bi-x-circle me-2"></i>Annuler
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
