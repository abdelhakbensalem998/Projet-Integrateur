@model IEnumerable<GestionHoraire.Models.Departement>

@{
    ViewData["Title"] = "Départements";
}

<div class="container py-5">
    <div class="row mb-5 align-items-center bg-white p-4 rounded-4 shadow-sm border-start border-5 border-warning justify-content-between">
        <div class="col-md-8">
            <h2 class="fw-bolder mb-1" style="color: #2c3e50;">
                <i class="bi bi-building me-2 text-warning"></i>Gestion des Départements
            </h2>
            <p class="text-secondary mb-0">Gérez les départements de l'établissement avec facilité et élégance</p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <a asp-action="Create" class="btn btn-warning btn-lg fw-bold shadow-sm rounded-pill px-4 transition-all hover-lift">
                <i class="bi bi-plus-circle-fill me-2"></i>Nouveau Département
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-4 border-0 border-start border-5 border-success mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2 fs-5 align-middle"></i>
            <span class="fw-medium">@TempData["SuccessMessage"]</span>
            <button type="button" class="btn-close mt-1" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden mb-5">
        <div class="card-header bg-gradient bg-light py-3 border-bottom border-light">
            <h5 class="mb-0 fw-bold text-secondary"><i class="bi bi-list-ul me-2"></i>Liste des départements (@Model.Count())</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background-color: #f8f9fa;">
                        <tr>
                            <th class="ps-5 py-3 border-0 text-uppercase text-secondary" style="font-size: 0.85rem; letter-spacing: 0.5px;">Nom du Département</th>
                            <th class="text-end pe-5 py-3 border-0 text-uppercase text-secondary" style="font-size: 0.85rem; letter-spacing: 0.5px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var item in Model)
                        {
                            <tr class="transition-all" style="transition: background-color 0.2s ease;">
                                <td class="ps-5 py-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                                            <i class="bi bi-building fs-5"></i>
                                        </div>
                                        <span class="fw-bold fs-5 text-dark">@item.Nom</span>
                                    </div>
                                </td>
                                <td class="text-end pe-5 py-4">
                                    <div class="btn-group shadow-sm rounded-pill" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary px-3 rounded-start-pill border-end-0 transition-all hover-bg-primary">
                                            <i class="bi bi-pencil-fill me-1"></i> Modifier
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger px-3 rounded-end-pill transition-all hover-bg-danger">
                                            <i class="bi bi-trash-fill me-1"></i> Supprimer
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                        
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="2" class="text-center py-5">
                                    <div class="text-muted d-flex flex-column align-items-center justify-content-center">
                                        <i class="bi bi-inbox fs-1 mb-3 text-secondary opacity-50"></i>
                                        <h5 class="fw-bold mb-1">Aucun département</h5>
                                        <p class="small mb-4">Commencez par ajouter votre premier département.</p>
                                        <a asp-action="Create" class="btn btn-outline-warning rounded-pill px-4">Créer maintenant</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-lift:hover {
        transform: translateY(-2px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
    .hover-bg-primary:hover {
        background-color: #0d6efd;
        color: white !important;
    }
    .hover-bg-danger:hover {
        background-color: #dc3545;
        color: white !important;
    }
    tr:hover {
        background-color: #f8f9fa !important;
    }
</style>
