@model GestionHoraire.Models.Departement

@{
    ViewData["Title"] = "Modifier le Département";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-primary text-white py-3 text-center fw-bold rounded-top-4">
                    <i class="bi bi-pencil-square me-2"></i>Modifier le Département
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="mb-4">
                            <label asp-for="Nom" class="form-label fw-bold">Nom du département</label>
                            <input asp-for="Nom" class="form-control" placeholder="ex: Informatique" />
                            <span asp-validation-for="Nom" class="text-danger small mt-1"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary fw-bold shadow-sm">
                                <i class="bi bi-save me-2"></i>Sauvegarder les modifications
                            </button>
                            <a asp-action="Index" class="btn btn-light shadow-sm">
                                <i class="bi bi-arrow-left me-2"></i>Retour à la liste
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
