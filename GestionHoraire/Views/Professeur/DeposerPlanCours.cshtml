@model GestionHoraire.Models.Demande
@{
    ViewData["Title"] = "Dépôt de document";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    body {
        background: #f8fafc;
        font-family: 'Outfit', sans-serif;
    }

    .premium-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(12px);
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
    }

    .card-header-gradient {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        color: white;
        border-radius: 24px 24px 0 0 !important;
        padding: 2rem 1.5rem;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px 20px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        font-family: 'Outfit', sans-serif;
    }

    .form-control:focus {
        box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        border-color: #4f46e5;
        background: white;
    }

    .btn-premium {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 600;
        font-family: 'Outfit', sans-serif;
        transition: all 0.3s;
    }

    .btn-premium:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(79, 70, 229, 0.2);
        color: white;
    }
    
    .upload-area {
        border: 2px dashed #cbd5e1;
        border-radius: 16px;
        background: #f8fafc;
        transition: all 0.2s ease;
        position: relative;
    }

    .upload-area:hover {
        border-color: #7c3aed;
        background: #eef2ff;
        transform: scale(1.01);
    }
    
    .cursor-pointer { cursor: pointer; }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Tableau de bord</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Déposer Plan de Cours</li>
                </ol>
            </nav>

            <div class="premium-card overflow-hidden">
                <div class="card-header-gradient text-center">
                    <i class="bi bi-file-earmark-arrow-up fs-1 mb-2 d-block text-white opacity-75"></i>
                    <h2 class="fw-bold m-0 text-white">Déposer Plan de Cours</h2>
                    <p class="small opacity-75 m-0 mt-1">Soumettez votre document pédagogique pour validation</p>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="DeposerPlanCours" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        
                        <div class="alert mb-4" style="border-radius: 12px; background: rgba(79, 70, 229, 0.05); border: 1px solid rgba(79, 70, 229, 0.1); color: #4338ca;">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-info-circle-fill fs-4 me-3"></i>
                                <span class="small fw-500">Les plans de cours déposés ici seront directement visibles par le responsable de département pour approbation.</span>
                            </div>
                        </div>

                        <div class="mb-4 mt-2">
                            <label class="form-label fw-bold text-muted small text-uppercase">
                                <i class="bi bi-pencil-square me-2" style="color: #4f46e5;"></i>Titre / Description du document
                            </label>
                            <input name="description" class="form-control" placeholder="Ex: Plan de cours Session Hiver 2026..." required />
                        </div>

                        <div class="mb-5">
                            <label class="form-label fw-bold text-muted small text-uppercase">
                                <i class="bi bi-cloud-upload d-inline-block me-2" style="color: #4f46e5;"></i>Fichier (PDF ou Word)
                            </label>
                            <div class="upload-area p-5 text-center cursor-pointer" id="dropArea">
                                <input type="file" name="fichier" class="form-control opacity-0 position-absolute top-0 start-0 w-100 h-100 cursor-pointer" accept=".pdf,.doc,.docx" required id="fileInput" />
                                <div id="fileInfo">
                                    <i class="bi bi-file-earmark-pdf fs-1 d-block mb-3" style="color: #94a3b8;"></i>
                                    <p class="fw-bold m-0" style="color: #334155;">Cliquez ou déposez votre fichier ici</p>
                                    <span class="small" style="color: #64748b;">Formats acceptés : .pdf, .doc, .docx (Max 10Mo)</span>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-premium fs-5">
                                <i class="bi bi-check-circle me-2"></i>Confirmer le dépôt
                            </button>
                            <a asp-action="Index" class="btn btn-light rounded-3 py-2 fw-bold text-center">
                                Annuler
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('fileInput').addEventListener('change', function(e) {
            const fileName = e.target.files[0]?.name || "Aucun fichier sélectionné";
            document.getElementById('fileInfo').innerHTML = `
                <i class="bi bi-file-earmark-check-fill fs-1 d-block mb-3" style="color: #4f46e5;"></i>
                <p class="fw-bold m-0" style="color: #4f46e5;">${fileName}</p>
                <span class="small" style="color: #64748b;">Prêt à être envoyé</span>
            `;
        });
    </script>
}
