@model GestionHoraire.Models.Demande
@{
    ViewData["Title"] = "Dépôt de document";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-gradient-success text-white text-center py-4 border-0" style="background: linear-gradient(45deg, #198754, #20c997);">
                    <i class="bi bi-file-earmark-arrow-up fs-1 mb-2 d-block text-white"></i>
                    <h2 class="fw-bold m-0 text-white">Déposer Plan de Cours</h2>
                    <p class="small opacity-75 m-0 mt-1">Soumettez votre document pédagogique pour validation</p>
                </div>
                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="DeposerPlanCours" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        
                        <div class="alert alert-info border-0 rounded-4 shadow-sm small py-3 px-4 mb-5 d-flex align-items-center">
                            <div class="p-2 bg-info bg-opacity-25 rounded-circle me-3">
                                <i class="bi bi-lightbulb-fill text-info"></i>
                            </div>
                            <span>Les plans de cours déposés ici seront directement visibles par le responsable de département pour approbation.</span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold"><i class="bi bi-pencil-square me-2 text-success"></i>Titre / Description du document</label>
                            <input name="description" class="form-control rounded-pill px-4 py-3 shadow-sm border-light bg-light" placeholder="Ex: Plan de cours Session Hiver 2026..." required />
                        </div>

                        <div class="mb-5">
                            <label class="form-label fw-bold"><i class="bi bi-cloud-upload-fill me-2 text-success"></i>Fichier (PDF ou Word)</label>
                            <div class="upload-area border border-2 border-dashed rounded-4 p-5 text-center bg-light transition-hover cursor-pointer position-relative" id="dropArea">
                                <input type="file" name="fichier" class="form-control opacity-0 position-absolute top-0 start-0 w-100 h-100 cursor-pointer" accept=".pdf,.doc,.docx" required id="fileInput" />
                                <div id="fileInfo">
                                    <i class="bi bi-file-earmark-pdf fs-1 text-muted mb-2 d-block"></i>
                                    <p class="m-0 text-muted">Cliquez ou déposez votre fichier ici</p>
                                    <span class="text-xs text-muted">Formats acceptés : .pdf, .doc, .docx (Max 10Mo)</span>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-success btn-lg rounded-pill shadow-sm fw-bold py-3 transition-hover">
                                <i class="bi bi-check-circle me-2"></i>Confirmer le dépôt
                            </button>
                            <a asp-action="Index" class="btn btn-link text-muted text-decoration-none small text-center">Annuler et revenir au tableau de bord</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover:hover { transform: scale(1.02); transition: transform 0.2s; }
    .upload-area:hover { border-color: #198754 !important; background: #fdfdfd !important; }
    .cursor-pointer { cursor: pointer; }
</style>

@section Scripts {
    <script>
        document.getElementById('fileInput').addEventListener('change', function(e) {
            const fileName = e.target.files[0]?.name || "Aucun fichier sélectionné";
            document.getElementById('fileInfo').innerHTML = `
                <i class="bi bi-file-earmark-check fs-1 text-success mb-2 d-block"></i>
                <p class="m-0 fw-bold text-success">${fileName}</p>
                <span class="text-xs text-muted">Prêt à être envoyé</span>
            `;
        });
    </script>
}
