@model IEnumerable<GestionHoraire.Models.Cours>
@{
    ViewData["Title"] = "Espace Professeur";
    var mesDemandes = (List<GestionHoraire.Models.Demande>)ViewBag.MesDemandes;
    var mesDispos = (List<GestionHoraire.Models.Disponibilite>)ViewBag.MesDisponibilites;
    
    var jours = new[] 
    { 
        new { Id = 1, Nom = "Lundi" },
        new { Id = 2, Nom = "Mardi" },
        new { Id = 3, Nom = "Mercredi" },
        new { Id = 4, Nom = "Jeudi" },
        new { Id = 5, Nom = "Vendredi" }
    };
    var slots = new[] { 
        new TimeSpan(8, 0, 0), 
        new TimeSpan(10, 0, 0), 
        new TimeSpan(12, 0, 0), 
        new TimeSpan(14, 0, 0), 
        new TimeSpan(16, 0, 0) 
    };
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    body {
        background: #f8fafc;
        font-family: 'Outfit', sans-serif;
        color: #1e293b;
    }

    :root {
        --primary-gradient: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        --glass-bg: rgba(255, 255, 255, 0.7);
        --glass-border: rgba(255, 255, 255, 0.4);
    }

    .premium-header {
        background: var(--primary-gradient);
        border-radius: 0 0 50px 50px;
        padding: 4rem 0 8rem 0;
        margin-bottom: -6rem;
        box-shadow: 0 10px 30px rgba(79, 70, 229, 0.2);
    }

    .glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.03);
    }

    .logout-btn {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(5px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white;
        border-radius: 50px;
        padding: 10px 25px;
        font-weight: 600;
        transition: all 0.2s;
    }

    .logout-btn:hover {
        background: rgba(255, 255, 255, 0.25);
        color: white;
        transform: translateY(-2px);
    }

    /* Grid Styles */
    .grid-cell { 
        height: 120px; 
        min-width: 140px; 
        vertical-align: top; 
        padding: 8px !important; 
        transition: background 0.3s; 
    }
    .grid-container {
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
        background: white;
    }
    .grid-table {
        margin: 0;
        border-collapse: collapse;
    }
    .grid-table th {
        background: #f8fafc;
        color: #64748b;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        padding: 1rem;
        border-bottom: 2px solid #e2e8f0;
    }
    .grid-table td {
        border: 1px solid #f1f5f9;
    }
    

    .course-card { 
        font-size: 0.8rem; 
        border-left: 4px solid #4f46e5; 
        background: white; 
        padding: 10px 12px; 
        border-radius: 12px; 
        box-shadow: 0 4px 10px rgba(79, 70, 229, 0.08);
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        transition: transform 0.2s;
    }
    .course-card:hover {
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 6px 15px rgba(79, 70, 229, 0.15);
    }

    /* Quick Actions */
    .btn-quick { 
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
        border-radius: 20px; 
        background: white;
        border: 1px solid #f1f5f9;
        position: relative;
        overflow: hidden;
        height: 100%;
    }
    .btn-quick:hover { 
        transform: translateY(-5px); 
        box-shadow: 0 15px 30px rgba(79, 70, 229, 0.1); 
        border-color: rgba(79, 70, 229, 0.2);
    }
    .icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
    
    .bg-soft-indigo { background: #e0e7ff; color: #4338ca; }
    .bg-soft-amber { background: #fef3c7; color: #b45309; }
    .bg-soft-emerald { background: #d1fae5; color: #059669; }

    .request-status { 
        border-radius: 50px; 
        font-size: 0.7rem; 
        padding: 4px 12px; 
        font-weight: 600;
    }
    .hover-opacity-100 { opacity: 0; transition: opacity 0.3s; }
    .grid-cell:hover .hover-opacity-100 { opacity: 1 !important; color: #4f46e5 !important; }
</style>

<div class="premium-header text-white">
    <div class="container-fluid px-4 px-lg-5 d-flex justify-content-between align-items-center">
        <div>
            <span class="opacity-75 small text-uppercase tracking-widest fw-bold">Espace Pédagogique</span>
            <h1 class="display-5 fw-bold mt-1">Bonjour, @ViewBag.UserNom.Split(' ')[0] 👋</h1>
            <p class="opacity-75 mb-0 fs-5"><i class="bi bi-mortarboard-fill me-2"></i>@ViewBag.UserRole - Session Automne 2026</p>
        </div>
        <a asp-controller="Login" asp-action="Logout" class="logout-btn text-decoration-none">
            <i class="bi bi-box-arrow-right me-2"></i>Déconnexion
        </a>
    </div>
</div>

<div class="container-fluid px-4 px-lg-5 pb-5">
    
    @if (TempData["Success"] != null)
    {
        <div class="alert glass-card border-0 d-flex align-items-center p-3 mb-4 mt-2" style="background: rgba(16, 185, 129, 0.1);">
            <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 35px; height: 35px;">
                <i class="bi bi-check-lg"></i>
            </div>
            <div class="fw-bold text-success">@TempData["Success"]</div>
        </div>
    }

    <!-- ACTIONS RAPIDES ET NOTIFICATIONS EN HAUT -->
    <div class="row g-4 mt-1 mb-4">
        
        <!-- Quick Actions -->
        <div class="col-xl-8 col-lg-7">
            <div class="glass-card p-4 h-100">
                <h5 class="fw-bold mb-4">Actions Rapides</h5>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="btn-quick p-3 d-flex flex-column align-items-start cursor-pointer shadow-sm">
                            <div class="icon-wrapper bg-soft-indigo mb-3"><i class="bi bi-calendar-week-fill"></i></div>
                            <div>
                                <h6 class="m-0 fw-bold text-dark">Disponibilités</h6>
                                <span class="small text-muted">Gérer mon emploi du temps</span>
                            </div>
                            <a asp-controller="Disponibilite" asp-action="Index" class="stretched-link"></a>
                        </div>
                    </div>
                    
                    <div class="col-md-4">
                        <div class="btn-quick p-3 d-flex flex-column align-items-start cursor-pointer shadow-sm">
                            <div class="icon-wrapper bg-soft-amber mb-3"><i class="bi bi-chat-square-text-fill"></i></div>
                            <div>
                                <h6 class="m-0 fw-bold text-dark">Demandes</h6>
                                <span class="small text-muted">Faire une requête</span>
                            </div>
                            <a asp-action="EnvoyerDemande" class="stretched-link"></a>
                        </div>
                    </div>
                    
                    <div class="col-md-4">
                        <div class="btn-quick p-3 d-flex flex-column align-items-start cursor-pointer shadow-sm">
                            <div class="icon-wrapper bg-soft-emerald mb-3"><i class="bi bi-file-earmark-arrow-up-fill"></i></div>
                            <div>
                                <h6 class="m-0 fw-bold text-dark">Plan de Cours</h6>
                                <span class="small text-muted">Soumettre un document</span>
                            </div>
                            <a asp-action="DeposerPlanCours" class="stretched-link"></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Feed Demandes -->
        <div class="col-xl-4 col-lg-5">
            <div class="glass-card p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold m-0">Requêtes Récentes</h5>
                    <a asp-action="MesDemandes" class="text-decoration-none small fw-bold" style="color: #4f46e5;">Voir tout</a>
                </div>
                
                <div class="d-flex flex-column gap-3">
                    @if (mesDemandes != null && mesDemandes.Any())
                    {
                        foreach (var d in mesDemandes.Take(2)) // We take 2 to save vertical space
                        {
                            <div class="p-3 bg-white rounded-4 border shadow-sm">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <span class="fw-bold small text-dark">@d.Type</span>
                                    <span class="request-status @(d.Statut == "Approuvé" ? "bg-soft-emerald border border-success" : (d.Statut == "Refusé" ? "bg-danger bg-opacity-10 text-danger border border-danger" : "bg-light text-muted border"))">
                                        @d.Statut
                                    </span>
                                </div>
                                <div class="text-muted d-flex align-items-center mt-2" style="font-size: 0.75rem;">
                                    <i class="bi bi-clock me-1"></i> @d.DateCreation.ToString("dd MMM yyyy • HH:mm")
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted bg-white rounded-4 border">
                            <i class="bi bi-inbox fs-2 opacity-50 d-block mb-2"></i>
                            <span class="small fw-bold">Aucune activité récente.</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- MA PLANIFICATION (GRID) EN BAS -->
        <div class="col-12">
            <div class="glass-card p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold m-0"><i class="bi bi-calendar-week me-2" style="color: #4f46e5;"></i>Mon Emploi du Temps</h4>
                </div>
                
                <div class="grid-container shadow-sm">
                    <div class="table-responsive">
                        <table class="table grid-table">
                            <thead>
                                <tr>
                                    <th style="width: 100px; text-align: center;">Heure</th>
                                    @foreach (var j in jours) { <th class="text-center">@j.Nom</th> }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in slots)
                                {
                                    <tr>
                                        <td class="bg-light align-middle text-center fw-bold" style="color: #64748b; font-size: 0.95rem;">
                                            @s.ToString(@"hh\:mm")
                                        </td>
                                        @foreach (var j in jours)
                                        {
                                            var hFin = s.Add(new TimeSpan(2, 0, 0));
                                            var dispos = mesDispos?.Where(d => (int)d.Jour == j.Id && d.HeureDebut < hFin && d.HeureFin > s).ToList();
                                            var matches = Model.Where(c => (int)c.Jour == j.Id && c.HeureDebut < hFin && c.HeureFin > s).ToList();
                                            
                                            <td class="grid-cell position-relative text-center">
                                                @if (matches.Any())
                                                {
                                                    foreach(var cours in matches) {
                                                        <div class="course-card text-start mb-2">
                                                            <div class="fw-bold text-dark text-truncate mb-1" style="font-size: 0.9rem;">@cours.Titre</div>
                                                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                                                <span class="text-muted small"><i class="bi bi-geo-alt-fill me-1" style="color: #94a3b8;"></i>@(cours.Salle?.Nom ?? "N/A")</span>
                                                                <span class="badge bg-indigo bg-opacity-10 text-indigo fw-bold" style="color: #4f46e5;">@cours.HeureDebut.ToString(@"hh\:mm")</span>
                                                            </div>
                                                        </div>
                                                    }
                                                }
                                                else if (dispos != null && dispos.Any())
                                                {
                                                    var dispo = dispos.OrderByDescending(d => d.Disponible).First();
                                                    <a asp-controller="Disponibilite" asp-action="Edit" asp-route-id="@dispo.Id" class="text-decoration-none">
                                                        <div class="badge @(dispo.Disponible ? "bg-success" : "bg-danger") bg-opacity-10 @(dispo.Disponible ? "text-success" : "text-danger") py-2 px-3 rounded-pill mt-3 shadow-sm border @(dispo.Disponible ? "border-success" : "border-danger")" style="font-size: 0.8rem;">
                                                            <i class="bi @(dispo.Disponible ? "bi-check-circle-fill" : "bi-x-circle-fill") me-1"></i>
                                                            @(dispo.Disponible ? "Disponible" : "Absent")
                                                        </div>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <a asp-controller="Disponibilite" asp-action="Create" asp-route-jour="@j.Id" asp-route-heure="@s.ToString(@"hh\:mm")" 
                                                       class="w-100 h-100 d-flex align-items-center justify-content-center hover-opacity-100 text-decoration-none position-absolute top-0 start-0">
                                                        <i class="bi bi-plus-circle-fill fs-3"></i>
                                                    </a>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
