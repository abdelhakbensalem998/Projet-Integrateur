@model IEnumerable<GestionHoraire.Models.Cours>
@{
    ViewData["Title"] = "Espace Professeur";
    var mesDemandes = (List<GestionHoraire.Models.Demande>)ViewBag.MesDemandes;
    var mesDispos = (List<GestionHoraire.Models.Disponibilite>)ViewBag.MesDisponibilites;
    
    var jours = new[] 
    { 
        new { Id = 1, Nom = "Lundi" },
        new { Id = 2, Nom = "Mardi" },
        new { Id = 3, Nom = "Mercredi" },
        new { Id = 4, Nom = "Jeudi" },
        new { Id = 5, Nom = "Vendredi" }
    };
    var slots = new[] { 
        new TimeSpan(8, 0, 0), 
        new TimeSpan(10, 0, 0), 
        new TimeSpan(12, 0, 0), 
        new TimeSpan(14, 0, 0), 
        new TimeSpan(16, 0, 0) 
    };
}

<style>
    :root {
        --prof-primary: #4361ee;
        --prof-success: #4cc9f0;
        --prof-bg: #f8f9fa;
    }
    .grid-cell { height: 120px; min-width: 140px; vertical-align: top; padding: 6px !important; transition: background 0.3s; }
    .bg-available { background-color: #f0fff4 !important; }
    .bg-unavailable { background-color: #fff5f5 !important; }
    .course-card { 
        font-size: 0.8rem; 
        border-left: 5px solid var(--prof-primary); 
        background: white; 
        padding: 10px; 
        border-radius: 10px; 
        box-shadow: 0 4px 12px rgba(67, 97, 238, 0.15);
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .btn-quick { transition: all 0.3s; border-radius: 12px; }
    .btn-quick:hover { transform: translateY(-3px); box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
    .request-status { border-radius: 20px; font-size: 0.7rem; padding: 2px 10px; }
</style>

<div class="container-fluid py-4 min-vh-100" style="background: var(--prof-bg);">
    <!-- Header Hero Section -->
    <div class="row mb-4 align-items-center bg-white p-4 rounded-4 shadow-sm mx-1">
        <div class="col-md-8">
            <h1 class="fw-bold text-dark m-0">Bonjour, <span class="text-primary">@ViewBag.UserNom</span></h1>
            <p class="text-muted m-0"><i class="bi bi-mortarboard-fill me-2"></i>@ViewBag.UserRole - Session Automne 2026</p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <a asp-controller="Login" asp-action="Logout" class="btn btn-outline-danger rounded-pill px-4">
                <i class="bi bi-power me-2"></i>Déconnexion
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-4 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <!-- MA PLANIFICATION (GRID) -->
        <div class="col-xl-9">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold m-0"><i class="bi bi-grid-3x3-gap me-2 text-primary"></i>Horaires & Disponibilités</h5>
                    <div class="d-flex gap-4 small text-muted">
                        <span><i class="bi bi-circle-fill text-success opacity-25 me-1"></i> Disponible</span>
                        <span><i class="bi bi-circle-fill text-danger opacity-25 me-1"></i> Absent</span>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered mb-0">
                            <thead class="bg-light text-center small text-uppercase">
                                <tr>
                                    <th style="width: 100px;">Heure</th>
                                    @foreach (var j in jours) { <th>@j.Nom</th> }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in slots)
                                {
                                    <tr>
                                        <td class="bg-light align-middle text-center fw-bold text-muted" style="font-size: 0.9rem;">
                                            @s.ToString(@"hh\:mm")
                                        </td>
                                        @foreach (var j in jours)
                                        {
                                            var hFin = s.Add(new TimeSpan(2, 0, 0));
                                            var dispos = mesDispos?.Where(d => (int)d.Jour == j.Id && d.HeureDebut < hFin && d.HeureFin > s).ToList();
                                            var matches = Model.Where(c => (int)c.Jour == j.Id && c.HeureDebut < hFin && c.HeureFin > s).ToList();
                                            
                                            var hasAbsence = dispos != null && dispos.Any(d => !d.Disponible);
                                            var hasDispo = dispos != null && dispos.Any(d => d.Disponible);
                                            var cellClass = hasAbsence ? "bg-unavailable" : (hasDispo ? "bg-available" : "");
                                            
                                            <td class="grid-cell @cellClass position-relative text-center">
                                                @if (matches.Any())
                                                {
                                                    foreach(var cours in matches) {
                                                        <div class="course-card text-start mb-1">
                                                            <div class="fw-bold text-dark text-truncate">@cours.Titre</div>
                                                            <div class="text-muted small"><i class="bi bi-geo-alt me-1"></i>@(cours.Salle?.Nom ?? "N/A")</div>
                                                            <div class="text-primary fw-bold mt-1" style="font-size: 0.7rem;">@cours.HeureDebut.ToString(@"hh\:mm")-@cours.HeureFin.ToString(@"hh\:mm")</div>
                                                        </div>
                                                    }
                                                }
                                                else if (dispos != null && dispos.Any())
                                                {
                                                    var dispo = dispos.OrderByDescending(d => d.Disponible).First();
                                                    <a asp-controller="Disponibilite" asp-action="Edit" asp-route-id="@dispo.Id" class="text-decoration-none">
                                                        <div class="badge @(dispo.Disponible ? "bg-success" : "bg-danger") opacity-75 py-2 px-3 rounded-pill mt-2 shadow-sm">
                                                            <i class="bi @(dispo.Disponible ? "bi-check-lg" : "bi-x-lg") me-1"></i>
                                                            @(dispo.Disponible ? "Disponible" : "Absent")
                                                        </div>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <a asp-controller="Disponibilite" asp-action="Create" asp-route-jour="@j.Id" asp-route-heure="@s.ToString(@"hh\:mm")" 
                                                       class="w-100 h-100 d-flex align-items-center justify-content-center text-muted opacity-0 hover-opacity-100 text-decoration-none position-absolute top-0 start-0">
                                                        <i class="bi bi-plus-circle-dotted fs-3"></i>
                                                    </a>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- ACTIONS & NOTIFICATIONS -->
        <div class="col-xl-3">
            <!-- Quick Actions -->
            <div class="row g-3 mb-4">
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 p-3 bg-white btn-quick">
                        <div class="d-flex align-items-center mb-2">
                           <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3"><i class="bi bi-calendar-plus text-primary fs-4"></i></div>
                           <h6 class="m-0 fw-bold">Gérer Disponibilités</h6>
                        </div>
                        <a asp-controller="Disponibilite" asp-action="Index" class="stretched-link"></a>
                    </div>
                </div>
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 p-3 bg-white btn-quick">
                        <div class="d-flex align-items-center mb-2">
                           <div class="bg-warning bg-opacity-10 p-2 rounded-3 me-3"><i class="bi bi-exclamation-triangle text-warning fs-4"></i></div>
                           <h6 class="m-0 fw-bold">Signaler et demande</h6>
                        </div>
                        <a asp-action="EnvoyerDemande" class="stretched-link"></a>
                    </div>
                </div>
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 p-3 bg-white btn-quick">
                        <div class="d-flex align-items-center mb-2">
                           <div class="bg-success bg-opacity-10 p-2 rounded-3 me-3"><i class="bi bi-file-earmark-arrow-up text-success fs-4"></i></div>
                           <h6 class="m-0 fw-bold">Déposer Plan Cours</h6>
                        </div>
                        <a asp-action="DeposerPlanCours" class="stretched-link"></a>
                    </div>
                </div>
            </div>

            <!-- Feed Demandes -->
            <div class="card border-0 shadow-sm rounded-4 bg-white">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="fw-bold m-0 text-muted small text-uppercase">Mes dernières demandes</h6>
                </div>
                <div class="card-body pt-0">
                    @if (mesDemandes != null && mesDemandes.Any())
                    {
                        foreach (var d in mesDemandes)
                        {
                            <div class="border-bottom py-3">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <span class="fw-bold small text-dark">@d.Type</span>
                                    <span class="request-status @(d.Statut == "Approuvé" ? "bg-success text-white" : (d.Statut == "Refusé" ? "bg-danger text-white" : "bg-light text-dark"))">
                                        @d.Statut
                                    </span>
                                </div>
                                <div class="text-muted" style="font-size: 0.75rem;">@d.DateCreation.ToString("dd MMM à HH:mm")</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted small">Aucune activité récente.</div>
                    }
                </div>
                <div class="card-footer bg-white border-0 text-center pb-3">
                    <a asp-action="MesDemandes" class="text-primary small text-decoration-none fw-bold">Tout voir <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-opacity-100:hover { opacity: 1 !important; transition: opacity 0.3s; }
</style>
