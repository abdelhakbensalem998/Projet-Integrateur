@model GestionHoraire.Models.Utilisateur

@{
    ViewData["Title"] = "Nouvel Utilisateur";
    var departements = ViewBag.Departements as List<GestionHoraire.Models.Departement>;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="container mt-5" style="max-width: 700px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 mb-0">Nouvel Utilisateur</h1>
        <a asp-controller="Admin" asp-action="Utilisateurs" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Retour
        </a>
    </div>

    <div class="card shadow border-0" style="border-radius:15px;">
        <div class="card-header bg-primary text-white" style="border-radius:15px 15px 0 0;">
            <h5 class="mb-0"><i class="bi bi-person-plus-fill me-2"></i>Créer un utilisateur</h5>
        </div>

        <div class="card-body">
            <form asp-controller="Admin" asp-action="CreateUser" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-bold">Nom complet</label>
                    <input asp-for="Nom" class="form-control" required />
                    <span asp-validation-for="Nom" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Email professionnel</label>
                    <input asp-for="Email" type="email" class="form-control" required />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Rôle assigné</label>
                    <select asp-for="Role" class="form-select">
                        <option value="Administrateur">Administrateur</option>
                        <option value="ResponsableDépartement">Responsable Département</option>
                        <option value="Professeur">Professeur</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Département</label>
                    <select asp-for="DepartementId" class="form-select">
                        <option value="">-- Choisir un département --</option>
                        @if (departements != null)
                        {
                            foreach (var d in departements)
                            {
                                <option value="@d.Id">@d.Nom</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="DepartementId" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-controller="Admin" asp-action="Utilisateurs" class="btn btn-secondary">Annuler</a>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-save me-1"></i> Enregistrer
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
