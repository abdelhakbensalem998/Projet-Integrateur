@model IEnumerable<GestionHoraire.Models.Utilisateur>

@{
    ViewData["Title"] = "Gestion des Utilisateurs";
    string userNom = ViewBag.UserNom as string ?? "Admin";
    string userRole = ViewBag.UserRole as string ?? "Administrateur";
    string roleFilter = Context.Request.Query["roleFilter"];
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    body {
        background: #f8fafc;
        font-family: 'Outfit', sans-serif;
        color: #1e293b;
    }

    :root {
        --primary-gradient: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        --glass-bg: rgba(255, 255, 255, 0.7);
        --glass-border: rgba(255, 255, 255, 0.4);
    }

    .premium-header {
        background: var(--primary-gradient);
        border-radius: 0 0 50px 50px;
        padding: 4rem 0 8rem 0;
        margin-bottom: -6rem;
        box-shadow: 0 10px 30px rgba(79, 70, 229, 0.2);
    }

    .glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.03);
    }

    .btn-pill {
        border-radius: 50px;
        padding: 10px 25px;
        font-weight: 600;
        transition: all 0.2s;
        border: none;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
    }

    .btn-header {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(5px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white;
    }

    .btn-header:hover {
        background: rgba(255, 255, 255, 0.25);
        color: white;
        transform: translateY(-2px);
    }

    .btn-add {
        background: white;
        color: #4f46e5;
    }

    .btn-add:hover {
        background: #f8fafc;
        color: #7c3aed;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    /* Premium Table Styles */
    .premium-table-container {
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        border: 1px solid #f1f5f9;
        margin-top: 2rem;
    }

    .premium-table thead th {
        background: #f8fafc;
        color: #64748b;
        font-weight: 700;
        text-uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        padding: 1.25rem 1.5rem;
        border-bottom: 2px solid #f1f5f9;
    }

    .premium-table tbody tr {
        transition: all 0.2s;
        border-bottom: 1px solid #f1f5f9;
    }

    .premium-table tbody tr:last-child {
        border-bottom: none;
    }

    .premium-table tbody tr:hover {
        background-color: #f8fafc;
        transform: scale(1.002);
    }

    .premium-table td {
        padding: 1.25rem 1.5rem;
        vertical-align: middle;
    }

    .user-avatar {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: var(--primary-gradient);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        margin-right: 1rem;
    }

    .badge-role {
        padding: 6px 14px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.75rem;
    }

    .bg-soft-indigo { background: #e0e7ff; color: #4338ca; }
    .bg-soft-emerald { background: #d1fae5; color: #065f46; }
    .bg-soft-amber { background: #fef3c7; color: #92400e; }
    .bg-soft-slate { background: #f1f5f9; color: #334155; }

    .action-btn {
        width: 35px;
        height: 35px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        text-decoration: none;
    }

    .action-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    .btn-edit:hover { color: #4f46e5; border-color: #4f46e5; }
    .btn-delete:hover { color: #ef4444; border-color: #ef4444; }

    .filter-select {
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        padding: 10px 15px;
        background: #f8fafc;
        font-size: 0.9rem;
    }

    .filter-select:focus {
        box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        border-color: #4f46e5;
    }
</style>

<div class="premium-header text-white">
    <div class="container d-flex justify-content-between align-items-center">
        <div>
            <span class="opacity-75 small text-uppercase tracking-widest fw-bold">Administration Système</span>
            <h1 class="display-4 fw-bold mt-1">Utilisateurs 👥</h1>
            <p class="opacity-75 mb-0 fs-5">Gérez les comptes, les rôles et les accès aux départements.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="CreateUser" class="btn-pill btn-add">
                <i class="bi bi-person-plus-fill me-2"></i>Nouveau Compte
            </a>
            <a asp-action="Dashboard" class="btn-pill btn-header">
                <i class="bi bi-house-door me-2"></i>Dashboard
            </a>
        </div>
    </div>
</div>

<div class="container pb-5">
    <!-- Messages Flash -->
    @if (TempData["Success"] != null)
    {
        <div class="alert glass-card border-0 d-flex align-items-center p-3 mb-5 mt-2" style="background: rgba(16, 185, 129, 0.1);">
            <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 35px; height: 35px;">
                <i class="bi bi-check-lg"></i>
            </div>
            <div class="fw-bold text-success">@TempData["Success"]</div>
        </div>
    }

    <!-- Zone de Filtre -->
    <div class="glass-card p-4 mb-4 mt-2">
        <form asp-action="Utilisateurs" method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-bold small text-uppercase text-muted">Filtrer par Rôle</label>
                <select name="roleFilter" class="form-select filter-select">
                    <option value="" selected="@(string.IsNullOrEmpty(roleFilter))">-- Tous les utilisateurs --</option>
                    <option value="Administrateur" selected="@(roleFilter == "Administrateur")">Administrateur</option>
                    <option value="ResponsableDépartement" selected="@(roleFilter == "ResponsableDépartement")">Responsable Département</option>
                    <option value="Professeur" selected="@(roleFilter == "Professeur")">Professeur</option>
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold py-2">
                    <i class="bi bi-funnel me-2"></i>Filtrer
                </button>
                <a asp-action="Utilisateurs" class="btn btn-light rounded-pill px-4 fw-bold py-2 border ms-2">
                    Effacer
                </a>
            </div>
        </form>
    </div>

    <!-- Tableau Premium -->
    <div class="premium-table-container">
        <div class="table-responsive">
            <table class="table premium-table m-0">
                <thead>
                    <tr>
                        <th style="width: 300px;">Utilisateur</th>
                        <th>Email</th>
                        <th>Rôle</th>
                        <th>Département</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="user-avatar">
                                            @user.Nom.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-bold">@user.Nom</div>
                                            <div class="text-muted small">Inscrit le @user.DateCreation.ToString("dd/MM/yy")</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-muted">@user.Email</td>
                                <td>
                                    @if (user.Role == "Administrateur")
                                    {
                                        <span class="badge-role bg-soft-indigo">Administrateur</span>
                                    }
                                    else if (user.Role == "ResponsableDépartement")
                                    {
                                        <span class="badge-role bg-soft-emerald">Responsable Dept.</span>
                                    }
                                    else
                                    {
                                        <span class="badge-role bg-soft-slate">Professeur</span>
                                    }
                                </td>
                                <td>
                                    @if (user.Departement != null)
                                    {
                                        <span class="small fw-600"><i class="bi bi-building me-1 opacity-50"></i>@user.Departement.Nom</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Global / Central</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="EditUser" asp-route-id="@user.Id" class="action-btn btn-edit" title="Modifier">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" onsubmit="return confirm('Supprimer cet utilisateur ?');" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="action-btn btn-delete" title="Supprimer">
                                                <i class="bi bi-trash3-fill"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-people display-6 opacity-25 d-block mb-3"></i>
                                Aucun utilisateur trouvé.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="text-center mt-5">
        <a asp-action="Dashboard" class="text-decoration-none text-muted fw-bold">
            <i class="bi bi-arrow-left me-2"></i>Retour au Dashboard
        </a>
    </div>
</div>
