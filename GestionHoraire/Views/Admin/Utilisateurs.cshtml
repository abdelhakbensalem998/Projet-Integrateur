@model IEnumerable<GestionHoraire.Models.Utilisateur>

@{
    ViewData["Title"] = "Gestion des Utilisateurs";
    string userNom = ViewBag.UserNom as string ?? "Admin";
    string userRole = ViewBag.UserRole as string ?? "Administrateur";
    string roleFilter = Context.Request.Query["roleFilter"];
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h1 class="h3 fw-bold m-0">Gestion des Utilisateurs</h1>
            <p class="text-muted m-0 mt-1">
                <i class="bi bi-person-badge me-2 text-primary"></i>
                @userNom — @userRole
            </p>
        </div>

        <div class="d-flex gap-2">
            <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-arrow-left me-1"></i> Dashboard
            </a>

            <a asp-controller="Admin" asp-action="CreateUser" class="btn btn-primary rounded-pill px-4">
                <i class="bi bi-plus-circle me-1"></i> Ajouter
            </a>
        </div>
    </div>

    <!-- Filtre -->
    <div class="card shadow-sm border-0 mb-3" style="border-radius:15px;">
        <div class="card-body">
            <form asp-controller="Admin" asp-action="Utilisateurs" method="get" class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Filtrer par rôle</label>
                    <select name="roleFilter" class="form-select">
                        <option value="" selected="@(string.IsNullOrEmpty(roleFilter))">-- Tous --</option>
                        <option value="Administrateur" selected="@(roleFilter == "Administrateur")">Administrateur</option>
                        <option value="ResponsableDépartement" selected="@(roleFilter == "ResponsableDépartement")">Responsable Département</option>
                        <option value="Professeur" selected="@(roleFilter == "Professeur")">Professeur</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <button class="btn btn-outline-primary">
                        <i class="bi bi-funnel me-1"></i> Appliquer
                    </button>

                    <a asp-controller="Admin" asp-action="Utilisateurs" class="btn btn-outline-secondary ms-2">
                        Réinitialiser
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Table -->
    <div class="card shadow border-0" style="border-radius:15px; overflow:hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary text-uppercase small fw-bold">
                    <tr>
                        <th class="ps-4">Nom</th>
                        <th>Email</th>
                        <th>Rôle</th>
                        <th>Département</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@user.Nom</td>
                                <td>@user.Email</td>

                                <td>
                                    @if (user.Role == "Administrateur")
                                    {
                                        <span class="badge rounded-pill bg-info text-dark">@user.Role</span>
                                    }
                                    else if (user.Role == "ResponsableDépartement")
                                    {

                                        <span class="badge rounded-pill bg-primary">@user.Role</span>
                                    }
                                    else
                                    {

                                        <span class="badge rounded-pill bg-secondary">@user.Role</span>
                                    }
                                </td>

                                <td>@(user.Departement?.Nom ?? "—")</td>

                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-controller="Admin" asp-action="EditUser" asp-route-id="@user.Id"
                                           class="btn btn-sm btn-outline-primary" title="Modifier">
                                            <i class="fas fa-edit"></i>
                                        </a>

                                        <form asp-controller="Admin" asp-action="DeleteUser" asp-route-id="@user.Id"
                                              method="post" class="m-0"
                                              onsubmit="return confirm('Supprimer @user.Nom ?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">
                                Aucun utilisateur trouvé.
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </div>

</div>
