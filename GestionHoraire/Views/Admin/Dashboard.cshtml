@{
    ViewData["Title"] = "Dashboard Admin";
    string userNom = ViewBag.UserNom;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    /* Carte principale */
    .card-module {
        position: relative;
        overflow: hidden; /* Empêche le badge de déborder à l'extérieur */
        border-radius: 20px !important;
        transition: all 0.3s ease-in-out;
    }

        .card-module:hover {
            transform: translateY(-8px);
            box-shadow: 0 1rem 2rem rgba(0,0,0,0.12) !important;
        }

    /* La Bulle Interne (Couleur thématique + texte blanc) */
    .inner-bubble {
        position: absolute;
        top: 15px; /* À l'intérieur du bord haut */
        right: 15px; /* À l'intérieur du bord droit */
        font-size: 0.9rem;
        padding: 0.4rem 0.8rem;
        font-weight: 800;
        border-radius: 10px;
        color: #ffffff !important; /* Nombre écrit en blanc */
        z-index: 5;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
</style>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-5 border-bottom pb-4">
        <h1 class="display-6 fw-bold text-dark m-0">@userNom</h1>
        <a asp-controller="Login" asp-action="Logout" class="btn btn-outline-danger rounded-pill px-4 fw-bold shadow-sm">
            <i class="bi bi-box-arrow-right me-2"></i>Déconnexion
        </a>
    </div>

    <div class="row g-5 text-center justify-content-center">

        <div class="col-md-6 col-lg-3">
            <a asp-controller="Admin" asp-action="Utilisateurs" class="text-decoration-none">
                <div class="card h-100 border-0 border-top border-primary border-4 shadow-sm hover-shadow card-module">
                    <span class="inner-bubble bg-primary">@ViewBag.TotalUsers</span>
                    <div class="card-body py-5">
                        <i class="bi bi-people-fill display-4 text-primary mb-3"></i>
                        <h4 class="fw-bold text-dark">Utilisateurs</h4>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-3">
            <a asp-controller="Salles" asp-action="Index" class="text-decoration-none">
                <div class="card h-100 border-0 border-top border-success border-4 shadow-sm hover-shadow card-module">
                    <span class="inner-bubble bg-success">@ViewBag.TotalSalles</span>
                    <div class="card-body py-5">
                        <i class="bi bi-door-open-fill display-4 text-success mb-3"></i>
                        <h4 class="fw-bold text-dark">Salles</h4>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-3">
            <a asp-controller="Groupes" asp-action="Index" class="text-decoration-none">
                <div class="card h-100 border-0 border-top border-info border-4 shadow-sm hover-shadow card-module">
                    <span class="inner-bubble bg-info">@ViewBag.TotalGroupes</span>
                    <div class="card-body py-5">
                        <i class="bi bi-mortarboard-fill display-4 text-info mb-3"></i>
                        <h4 class="fw-bold text-dark">Groupes</h4>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-3">
            <a asp-controller="Departements" asp-action="Index" class="text-decoration-none">
                <div class="card h-100 border-0 border-top border-warning border-4 shadow-sm hover-shadow card-module">
                    <span class="inner-bubble bg-warning">@ViewBag.TotalDepts</span>
                    <div class="card-body py-5">
                        <i class="bi bi-building-fill display-4 text-warning mb-3"></i>
                        <h4 class="fw-bold text-dark">Départements</h4>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-3">
            <a asp-controller="Planning" asp-action="Index" class="text-decoration-none">
                <div class="card h-100 border-0 border-top border-secondary border-4 shadow-sm hover-shadow card-module">
                    <span class="inner-bubble bg-secondary">
                        <i class="bi bi-calendar-check"></i>
                    </span>
                    <div class="card-body py-5">
                        <i class="bi bi-calendar-week-fill display-4 text-secondary mb-3"></i>
                        <h4 class="fw-bold text-dark">Planning</h4>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-3">
            <a asp-controller="Affectations" asp-action="Index" class="text-decoration-none">
                <div class="card h-100 border-0 border-top border-danger border-4 shadow-sm hover-shadow card-module">
                    <span class="inner-bubble bg-danger">
                        <i class="bi bi-journal-check"></i>
                    </span>
                    <div class="card-body py-5">
                        <i class="bi bi-person-lines-fill display-4 text-danger mb-3"></i>
                        <h4 class="fw-bold text-dark">Affectations</h4>
                    </div>
                </div>
            </a>
        </div>

    </div>
</div>