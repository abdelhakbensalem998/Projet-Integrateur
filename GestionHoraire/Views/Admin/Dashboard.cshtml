@{
    ViewData["Title"] = "Dashboard Admin";
    string userNom = ViewBag.UserNom as string ?? "Admin";
    string userRole = ViewBag.UserRole as string ?? "Administrateur";
}

<style>
    .hover-shadow {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .hover-shadow:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15) !important;
        }

    .card-module {
        border-radius: 15px;
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-5 border-bottom pb-4">
        <div>
            <h1 class="display-6 fw-bold text-dark m-0">@userNom</h1>
            <p class="text-muted fs-5 m-0 mt-1">
                <i class="bi bi-shield-lock-fill me-2 text-primary"></i>
                @userRole
            </p>
        </div>

        <a asp-controller="Login" asp-action="Logout"
           class="btn btn-outline-danger d-flex align-items-center gap-2 rounded-pill px-4 shadow-sm fw-bold text-decoration-none">
            <i class="bi bi-box-arrow-right"></i>
            <span>Déconnexion</span>
        </a>
    </div>

  =
    <div class="row g-4 text-center justify-content-center">

    
        <div class="col-md-4 col-lg-3">
            <a asp-controller="Admin" asp-action="Utilisateurs" class="text-decoration-none text-dark">
                <div class="card h-100 shadow-sm hover-shadow border-0 border-top border-primary border-4 card-module">
                    <div class="card-body py-5">
                        <i class="bi bi-people-fill display-4 text-primary mb-3"></i>
                        <h3 class="fw-bold h4">Utilisateurs</h3>
                        <p class="text-muted mb-0">Liste + filtre + ajouter</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- Salles -->
        <div class="col-md-4 col-lg-3">
            <a asp-controller="Salles" asp-action="Index" class="text-decoration-none text-dark">
                <div class="card h-100 shadow-sm hover-shadow border-0 border-top border-success border-4 card-module">
                    <div class="card-body py-5">
                        <i class="bi bi-door-open-fill display-4 text-success mb-3"></i>
                        <h3 class="fw-bold h4">Salles</h3>
                        <p class="text-muted mb-0">Gestion des locaux</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- Groupes -->
        <div class="col-md-4 col-lg-3">
            <a asp-controller="Groupes" asp-action="Index" class="text-decoration-none text-dark">
                <div class="card h-100 shadow-sm hover-shadow border-0 border-top border-info border-4 card-module">
                    <div class="card-body py-5">
                        <i class="bi bi-mortarboard-fill display-4 text-info mb-3"></i>
                        <h3 class="fw-bold h4">Groupes</h3>
                        <p class="text-muted mb-0">Gestion des classes</p>
                    </div>
                </div>
            </a>
        </div>

    </div>
</div>
