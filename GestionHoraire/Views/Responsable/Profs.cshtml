@model IEnumerable<GestionHoraire.Models.Utilisateur>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-success fw-bold"><i class="bi bi-people-fill me-2"></i>Équipe Pédagogique</h2>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-3 shadow-sm">
                <i class="bi bi-house-door me-1"></i> Tableau de bord
            </a>
            <a asp-action="CreerProf" class="btn btn-success rounded-pill px-4 shadow-sm">
                <i class="bi bi-person-plus-fill me-1"></i> Ajouter un Enseignant
            </a>
        </div>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card prof-card shadow-sm border-0 h-100 overflow-hidden">
                    <div class="card-body p-0">
                        <!-- Card Content -->
                        <div class="p-4 d-flex align-items-center">
                            <div class="avatar-circle bg-success-subtle text-success p-3 me-3">
                                <i class="bi bi-person-badge fs-2"></i>
                            </div>
                            <div class="prof-info">
                                <h5 class="card-title mb-0 fw-bold">@item.Nom</h5>
                                <p class="text-muted small mb-0"><i class="bi bi-envelope-at me-1"></i>@item.Email</p>
                            </div>
                        </div>

                        <!-- Hover Overlay -->
                        <div class="prof-overlay d-flex flex-column justify-content-center align-items-center p-3">
                            <a asp-controller="Disponibilite" asp-action="Index" 
                               asp-route-professeurId="@item.Id" 
                               asp-route-returnUrl="/Responsable/Profs" 
                               class="btn btn-info btn-sm rounded-pill mb-2 w-75 shadow-sm hover-scale text-white">
                                 <i class="bi bi-calendar-check me-1"></i> Gérer Disponibilités
                             </a>
                            <a asp-action="EditerProf" asp-route-id="@item.Id" 
                               class="btn btn-primary btn-sm rounded-pill mb-2 w-75 shadow-sm hover-scale">
                                <i class="bi bi-pencil-square me-1"></i> Modifier
                            </a>
                            <form asp-action="SupprimerProf" asp-route-id="@item.Id" method="post" 
                                  onsubmit="return confirm('Supprimer cet enseignant ?');" class="w-75">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger btn-sm rounded-pill w-100 shadow-sm hover-scale" title="Supprimer">
                                    <i class="bi bi-trash-fill me-1"></i> Supprimer
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .prof-card {
        position: relative;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 15px;
        background: #fff;
    }

    .avatar-circle {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }

    .prof-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255, 255, 255, 0.6); /* Transparent au lieu de sombre */
        opacity: 0;
        visibility: hidden;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        transform: scale(0.9);
        backdrop-filter: blur(8px); /* Effet flou transparent */
        border-radius: 15px;
    }

    .prof-card:hover .prof-overlay {
        opacity: 1;
        visibility: visible;
        transform: scale(1);
    }

    .prof-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }

    .hover-scale {
        transition: transform 0.2s ease;
    }

    .hover-scale:hover {
        transform: scale(1.05);
    }
</style>