@model IEnumerable<GestionHoraire.Models.Utilisateur>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-success fw-bold"><i class="bi bi-people-fill me-2"></i>Équipe Pédagogique</h2>
        <a asp-action="CreerProf" class="btn btn-success rounded-pill px-4 shadow-sm">
            <i class="bi bi-person-plus-fill me-1"></i> Ajouter un Enseignant
        </a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-success-subtle text-success rounded-circle p-3 me-3">
                                <i class="bi bi-person-badge fs-3"></i>
                            </div>
                            <div>
                                <h5 class="card-title mb-0 fw-bold">@item.Nom</h5>
                                <p class="text-muted small mb-0">@item.Email</p>
                            </div>
                        </div>
                        <div class="d-grid gap-2 mt-4">
                            <a asp-controller="Affectations" asp-action="VoirDispos" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-calendar-check me-1"></i> Gérer Disponibilités
                            </a>
                            <div class="btn-group w-100">
                                <a asp-action="EditerProf" asp-route-id="@item.Id" class="btn btn-light btn-sm border">
                                    <i class="bi bi-pencil me-1"></i> Modifier
                                </a>
                                <form asp-action="SupprimerProf" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Supprimer cet enseignant ?');" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-light btn-sm border-start-0 border text-danger w-100">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>