@model IEnumerable<GestionHoraire.Models.Utilisateur>

@{
    ViewData["Title"] = "Équipe Pédagogique";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

<div class="page-header py-5 mb-5">
    <div class="container">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div class="header-text">
                <h1 class="display-5 fw-bold text-white mb-2">
                    <i class="bi bi-people-fill me-3"></i>Équipe Pédagogique
                </h1>
                <p class="text-white-50 mb-0 fs-5">Gérez vos enseignants et leurs accès en toute simplicité.</p>
            </div>
            <div class="header-actions">
                <a asp-action="CreerProf" class="btn btn-light btn-lg rounded-pill px-4 shadow-lg hover-up">
                    <i class="bi bi-person-plus-fill me-2"></i> Ajouter un Enseignant
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 px-4 py-3 mb-4 animate-fade-in" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill me-3 fs-4"></i>
                <div>@TempData["Success"]</div>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm rounded-4 px-4 py-3 mb-4 animate-fade-in" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-exclamation-triangle-fill me-3 fs-4"></i>
                <div>@TempData["Error"]</div>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-xl-4 col-lg-6">
                <div class="prof-card bg-white rounded-4 border-0 shadow-sm overflow-hidden h-100 position-relative">
                    <div class="card-body p-0">
                        <!-- Top Banner / Accents -->
                        <div class="accent-bar bg-primary-gradient"></div>
                        
                        <div class="p-4">
                            <div class="d-flex align-items-center mb-4">
                                <div class="avatar-box bg-light rounded-4 me-3 d-flex align-items-center justify-content-center">
                                    <span class="fs-2 fw-bold text-primary">@item.Nom.Substring(0, 1).ToUpper()</span>
                                </div>
                                <div class="info">
                                    <h4 class="fw-bold text-dark mb-1">@item.Nom</h4>
                                    <span class="badge bg-primary-subtle text-primary rounded-pill px-3">Professeur</span>
                                </div>
                            </div>

                            <div class="contact-info mb-4">
                                <div class="d-flex align-items-center mb-2 text-muted">
                                    <i class="bi bi-envelope me-2"></i> @item.Email
                                </div>
                                <div class="d-flex align-items-center text-muted">
                                    <i class="bi bi-building me-2"></i> @(item.Departement?.Nom ?? "Département assigné")
                                </div>
                            </div>
                        </div>

                        <!-- Actions Grid (Visible on Hover / Fixed on Mobile) -->
                        <div class="prof-actions p-4 border-top bg-light-subtle d-flex flex-wrap gap-2">
                             <a asp-controller="Disponibilite" asp-action="Index" 
                               asp-route-professeurId="@item.Id" 
                               asp-route-returnUrl="/Responsable/Profs" 
                               class="btn btn-outline-info flex-grow-1 rounded-pill py-2">
                                 <i class="bi bi-calendar-check"></i> Dispos
                             </a>
                             <a asp-action="EditerProf" asp-route-id="@item.Id" 
                               class="btn btn-outline-primary flex-grow-1 rounded-pill py-2">
                                <i class="bi bi-pencil"></i> Modifier
                            </a>
                            <form asp-action="ReinitialiserMotDePasse" asp-route-id="@item.Id" method="post" 
                                  onsubmit="return confirm('Réinitialiser le mot de passe de cet enseignant ?');" class="flex-grow-1">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-warning w-100 rounded-pill py-2">
                                    <i class="bi bi-shield-lock"></i> Reset MDP
                                </button>
                            </form>
                            <form asp-action="SupprimerProf" asp-route-id="@item.Id" method="post" 
                                  onsubmit="return confirm('Souhaitez-vous vraiment supprimer cet enseignant ?');" class="flex-grow-1">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger w-100 rounded-pill py-2">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="empty-state">
                    <i class="bi bi-people text-muted opacity-25" style="font-size: 5rem;"></i>
                    <h3 class="mt-3 text-muted">Aucun enseignant trouvé</h3>
                    <p class="text-muted">Commencez par ajouter un professeur à votre équipe.</p>
                </div>
            </div>
        }
    </div>
</div>

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #2563eb, #3b82f6);
        --bg-glass: rgba(255, 255, 255, 0.8);
    }

    body {
        background-color: #f8fafc;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .page-header {
        background: linear-gradient(135deg, #1e40af, #2563eb);
        border-radius: 0 0 50px 50px;
        box-shadow: 0 10px 30px rgba(30, 64, 175, 0.2);
    }

    .bg-primary-gradient {
        background: var(--primary-gradient);
    }

    .accent-bar {
        height: 6px;
        width: 100%;
    }

    .prof-card {
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        border: 1px solid rgba(0,0,0,0.05) !important;
    }

    .prof-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.08) !important;
    }

    .avatar-box {
        width: 70px;
        height: 70px;
        transition: all 0.3s ease;
    }

    .prof-card:hover .avatar-box {
        background: #2563eb !important;
    }

    .prof-card:hover .avatar-box span {
        color: white !important;
    }

    .prof-actions {
        opacity: 0.7;
        transition: all 0.3s ease;
    }

    .prof-card:hover .prof-actions {
        opacity: 1;
        background-color: white;
    }

    .btn-outline-info:hover, .btn-outline-primary:hover, .btn-outline-warning:hover, .btn-outline-danger:hover {
        color: white !important;
    }

    .hover-up {
        transition: transform 0.2s ease;
    }

    .hover-up:hover {
        transform: translateY(-3px);
    }

    .animate-fade-in {
        animation: fadeIn 0.5s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Mobile handling: actions always visible */
    @@media (max-width: 991px) {
        .prof-actions {
            opacity: 1;
        }
    }
</style>