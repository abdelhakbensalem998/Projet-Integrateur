@{
    ViewData["Title"] = "Accueil Responsable";
}

<div class="container mt-5">
    <h1 class="text-center mb-5 border-bottom pb-3">Tableau de Bord Responsable</h1>

    <div class="row g-4">
        <div class="col-md-4">
            <a asp-action="Salles" class="text-decoration-none text-dark">
                <div class="card h-100 shadow-sm hover-shadow border-primary">
                    <div class="card-body text-center py-5">
                        <h3 class="card-title">Salles</h3>
                        <p class="text-muted">Gérer les locaux et capacités</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-action="Profs" class="text-decoration-none text-dark">
                <div class="card h-100 shadow-sm hover-shadow border-success">
                    <div class="card-body text-center py-5">
                        <h3 class="card-title">Professeurs</h3>
                        <p class="text-muted">Disponibilités et affectations</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-action="Groupes" class="text-decoration-none text-dark">
                <div class="card h-100 shadow-sm hover-shadow border-warning">
                    <div class="card-body text-center py-5">
                        <h3 class="card-title">Planning</h3>
                        <p class="text-muted">Générer l'emploi du temps</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>