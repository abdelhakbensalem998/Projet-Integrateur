@model GestionHoraire.Models.Utilisateur

@{
    ViewData["Title"] = "Tableau de Bord";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    body {
        background: #f8fafc;
        font-family: 'Outfit', sans-serif;
        color: #1e293b;
    }

    :root {
        --primary-gradient: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        --glass-bg: rgba(255, 255, 255, 0.7);
        --glass-border: rgba(255, 255, 255, 0.4);
    }

    .premium-header {
        background: var(--primary-gradient);
        border-radius: 0 0 50px 50px;
        padding: 4rem 0 8rem 0;
        margin-bottom: -6rem;
        box-shadow: 0 10px 30px rgba(79, 70, 229, 0.2);
    }

    .glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.03);
    }

    .hover-scale:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
        border-color: rgba(79, 70, 229, 0.3);
    }

    .module-icon {
        width: 60px;
        height: 60px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .bg-soft-success { background: #dcfce7; color: #166534; }
    .bg-soft-primary { background: #e0e7ff; color: #3730a3; }
    .bg-soft-warning { background: #fef9c3; color: #854d0e; }
    .bg-soft-error { background: #fee2e2; color: #991b1b; }
    .bg-soft-info { background: #e0f2fe; color: #075985; }
    .bg-soft-dark { background: #f1f5f9; color: #334155; }

    .bento-stat {
        border-radius: 20px;
        padding: 1.5rem;
        background: white;
        border: 1px solid #f1f5f9;
        height: 100%;
    }

    .counter-badge {
        position: absolute;
        top: 20px;
        right: 20px;
        background: #f1f5f9;
        color: #475569;
        padding: 4px 12px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.8rem;
    }

    .logout-btn {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(5px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white;
        border-radius: 50px;
        padding: 10px 25px;
        font-weight: 600;
        transition: all 0.2s;
    }

    .logout-btn:hover {
        background: rgba(255, 255, 255, 0.25);
        color: white;
    }

    .search-pill {
        border-radius: 50px;
        padding: 12px 25px;
        background: white;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    /* Pulse animation for urgent requests */
    .pulse-urgent {
        box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
        animation: pulse 1.5s infinite;
    }

    @@keyframes pulse {
        0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
        70% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
        100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
    }
</style>

<div class="premium-header text-white">
    <div class="container d-flex justify-content-between align-items-center">
        <div>
            <span class="opacity-75 small text-uppercase tracking-widest fw-bold">Espace de Pilotage</span>
            <h1 class="display-4 fw-bold mt-1">Bonjour, @Model.Nom.Split(' ')[0] 👋</h1>
            <p class="opacity-75 mb-0 fs-5"><i class="bi bi-mortarboard-fill me-2"></i>@(Model.Departement?.Nom ?? "Département Général")</p>
        </div>
        <a asp-controller="Login" asp-action="Logout" class="logout-btn text-decoration-none">
            <i class="bi bi-box-arrow-right me-2"></i>Déconnexion
        </a>
    </div>
</div>

<div class="container pb-5">
    <!-- Messages Flash -->
    @if (TempData["Success"] != null)
    {
        <div class="alert glass-card border-0 d-flex align-items-center p-3 mb-5 mt-4" style="background: rgba(16, 185, 129, 0.1);">
            <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 35px; height: 35px;">
                <i class="bi bi-check-lg"></i>
            </div>
            <div class="fw-bold text-success">@TempData["Success"]</div>
        </div>
    }

    <!-- Grille des Modules -->
    <div class="row g-4 mt-1">
        <!-- Professeurs -->
        <div class="col-md-4">
            <a asp-action="Profs" class="text-decoration-none text-dark d-block h-100">
                <div class="glass-card p-4 hover-scale h-100 position-relative">
                    <span class="counter-badge">@ViewBag.NbProfesseurs Profils</span>
                    <div class="module-icon bg-soft-success">
                        <i class="bi bi-person-badge"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Équipe Pédagogique</h4>
                    <p class="text-muted small">Gérez les professeurs, leurs spécialités et comptes.</p>
                </div>
            </a>
        </div>

        <!-- Groupes -->
        <div class="col-md-4">
            <a asp-controller="Groupes" asp-action="Index" class="text-decoration-none text-dark d-block h-100">
                <div class="glass-card p-4 hover-scale h-100 position-relative">
                    <span class="counter-badge">@ViewBag.NbGroupes Classes</span>
                    <div class="module-icon bg-soft-primary">
                        <i class="bi bi-mortarboard"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Groupes / Étudiants</h4>
                    <p class="text-muted small">Organisation des niveaux et membres des classes.</p>
                </div>
            </a>
        </div>

        <!-- Affectations -->
        <div class="col-md-4">
            <a asp-controller="Affectations" asp-action="Index" class="text-decoration-none text-dark d-block h-100">
                <div class="glass-card p-4 hover-scale h-100 position-relative border-2 border-primary-subtle shadow-lg" style="background: white;">
                    <div class="module-icon bg-soft-error">
                        <i class="bi bi-node-plus-fill"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Service & Affectations</h4>
                    <p class="text-muted small">Attribuez les cours aux professeurs et salles.</p>
                    <div class="mt-3">
                        <span class="badge rounded-pill bg-danger-subtle text-danger px-3 py-2">Module Prioritaire</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- Planning -->
        <div class="col-md-4">
            <a asp-controller="Planning" asp-action="Index" class="text-decoration-none text-dark d-block h-100">
                <div class="glass-card p-4 hover-scale h-100 position-relative">
                    <div class="module-icon bg-soft-warning">
                        <i class="bi bi-calendar3-range"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Planning Global</h4>
                    <p class="text-muted small">Consultez l'emploi du temps par groupe ou prof.</p>
                </div>
            </a>
        </div>

        <!-- Demandes -->
        <div class="col-md-4">
            <a asp-action="Demandes" class="text-decoration-none text-dark d-block h-100">
                <div class="glass-card p-4 hover-scale h-100 position-relative @(ViewBag.NbDemandesEnAttente > 0 ? "border-danger-emphasis" : "")">
                    @if (ViewBag.NbDemandesEnAttente > 0)
                    {
                        <span class="badge bg-danger position-absolute pulse-urgent" style="top:20px; right:20px; border-radius: 50px;">
                            @ViewBag.NbDemandesEnAttente Nouveau@(ViewBag.NbDemandesEnAttente > 1 ? "x" : "")
                        </span>
                    }
                    <div class="module-icon bg-soft-primary">
                        <i class="bi bi-chat-dots"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Demandes Profs</h4>
                    <p class="text-muted small">Validez les vacances, documents et requêtes.</p>
                </div>
            </a>
        </div>

        <!-- Salles -->
        <div class="col-md-4">
            <a asp-controller="Salles" asp-action="Index" class="text-decoration-none text-dark d-block h-100">
                <div class="glass-card p-4 hover-scale h-100 position-relative">
                    <span class="counter-badge">@ViewBag.NbSalles Locaux</span>
                    <div class="module-icon bg-soft-dark">
                        <i class="bi bi-building"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Infrastructure</h4>
                    <p class="text-muted small">Gestion des salles de cours et laboratoires.</p>
                </div>
            </a>
        </div>
    </div>

    <!-- Section Statistiques (Bento Grid) -->
    <div class="mt-5">
        <h4 class="fw-bold mb-4 d-flex align-items-center">
            <i class="bi bi-bar-chart-fill text-primary me-2"></i> Performance & Vigilance
        </h4>
        <div class="row g-4">
            <div class="col-md-6">
                <div class="bento-stat glass-card border-0">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div>
                            <h6 class="text-muted fw-bold small text-uppercase">Taux d'assignation des cours</h6>
                            <div class="display-5 fw-bold text-dark mt-2">@ViewBag.TauxAssignation%</div>
                        </div>
                        <div class="bg-primary-subtle text-primary p-3 rounded-circle">
                            <i class="bi bi-check-all fs-4"></i>
                        </div>
                    </div>
                    <div class="progress" style="height: 10px; border-radius: 20px;">
                        <div class="progress-bar" role="progressbar" style="width: @ViewBag.TauxAssignation%; background: var(--primary-gradient);"></div>
                    </div>
                    <p class="text-muted mt-3 small mb-0">Sur un total de <span class="fw-bold">@ViewBag.NbCoursTotal</span> cours déclarés.</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="bento-stat glass-card border-0 text-center @((int)ViewBag.NbConflits > 0 ? "border-bottom border-danger border-4" : "")">
                    <h6 class="text-muted fw-bold small text-uppercase mb-3">Conflits d'horaire</h6>
                    <div class="display-6 fw-bold @((int)ViewBag.NbConflits > 0 ? "text-danger" : "text-success")">@ViewBag.NbConflits</div>
                    <div class="mt-3">
                        @if((int)ViewBag.NbConflits > 0) {
                            <span class="badge bg-danger px-3 py-2 rounded-pill"><i class="bi bi-exclamation-triangle me-1"></i>Action requise</span>
                        } else {
                            <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill"><i class="bi bi-patch-check me-1"></i>Sain</span>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="bento-stat glass-card border-0 text-center">
                    <h6 class="text-muted fw-bold small text-uppercase mb-3">Surcharge de Charge</h6>
                    <div class="display-6 fw-bold @((int)ViewBag.NbSurcharges > 0 ? "text-warning" : "text-dark")">@ViewBag.NbSurcharges</div>
                    <div class="mt-3">
                        @if((int)ViewBag.NbSurcharges > 0) {
                            <span class="badge bg-warning-subtle text-warning-emphasis px-3 py-2 rounded-pill">Vérifier quotas</span>
                        } else {
                            <span class="badge bg-info-subtle text-info px-3 py-2 rounded-pill">Équilibré</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
>
    </div>
</div>