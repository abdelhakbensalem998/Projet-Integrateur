@model IEnumerable<GestionHoraire.Models.Utilisateur>

@{
    ViewData["Title"] = "Mon Équipe Pédagogique";
    // On essaie de récupérer le nom du département depuis le premier prof de la liste
    var nomDepartement = Model.FirstOrDefault()?.Departement?.Nom ?? "Département";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary"><i class="bi bi-people-fill me-2"></i>@nomDepartement</h2>
            <p class="text-muted">Liste des professeurs sous votre responsabilité</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour Dashboard
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Nom complet</th>
                            <th>Email professionnel</th>
                            <th>Spécialité / Dept</th>
                            <th class="text-center">Disponibilités</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var prof in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">
                                    <i class="bi bi-person-circle me-2 text-secondary"></i>@prof.Nom
                                </td>
                                <td>
                                    <a href="mailto:@prof.Email" class="text-decoration-none">@prof.Email</a>
                                </td>
                                <td>
                                    <span class="badge bg-info text-dark">
                                        @(prof.Departement?.Nom ?? "Non assigné")
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a asp-action="VoirDispos" asp-route-id="@prof.Id" class="btn btn-sm btn-primary">
                                        <i class="bi bi-calendar3"></i> Voir l'agenda
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-3 text-end">
            <small class="text-muted">Nombre de professeurs trouvés : @Model.Count()</small>
        </div>
    }
    else
    {
        <div class="alert alert-info d-flex align-items-center shadow-sm" role="alert">
            <i class="bi bi-info-circle-fill fs-4 me-3"></i>
            <div>
                <strong>Aucun professeur trouvé.</strong><br />
                Assurez-vous que les professeurs sont bien assignés à votre département dans la base de données.
            </div>
        </div>
    }
</div>

<style>
    .table thead th {
        border-top: none;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 1px;
    }

    .hover-shadow:hover {
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        transition: 0.3s;
    }
</style>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}