@model GestionHoraire.Models.Disponibilite
@{
    ViewData["Title"] = "Supprimer créneau";
}

<div class="container mt-4">
    <div class="card border-danger shadow">
        <div class="card-header bg-danger text-white">
            <h4>🗑️ Confirmer suppression</h4>
        </div>
        <div class="card-body">
            <h5>Créneau à supprimer</h5>
            <div class="alert alert-danger">
                <strong>@GetJourNom(Model.Jour)</strong><br />
                @Model.HeureDebut.ToString(@"hh\:mm") - @Model.HeureFin.ToString(@"hh\:mm")<br />
                <small class="text-muted">Pour @Model.Utilisateur.Nom @Model.Utilisateur.Nom</small>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="UtilisateurId" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Oui, supprimer
                    </button>
                    <a asp-action="Index" asp-route-professeurId="@Model.UtilisateurId"
                       class="btn btn-secondary">← Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

@functions {
    string GetJourNom(DayOfWeek jour) => jour switch
    {
        DayOfWeek.Monday => "Lundi",
        DayOfWeek.Tuesday => "Mardi",
        DayOfWeek.Wednesday => "Mercredi",
        DayOfWeek.Thursday => "Jeudi",
        DayOfWeek.Friday => "Vendredi",
        DayOfWeek.Saturday => "Samedi",
        _ => "Dimanche"
    };
}
