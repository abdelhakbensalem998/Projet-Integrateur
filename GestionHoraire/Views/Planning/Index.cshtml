@model IEnumerable<GestionHoraire.Models.Cours>

@{
    ViewData["Title"] = "Planning Hebdomadaire";
    var joursNoms = new[] { "Lundi", "Mardi", "Mercredi", "Jeudi", "Vendredi" };
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 shadow-sm rounded border-start border-4 border-primary">
        <div>
            <h2 class="fw-bold text-dark m-0"><i class="bi bi-calendar3 text-primary me-2"></i>Planning</h2>
            <div id="statusMessage" class="small mt-1 text-muted">Prêt</div>
        </div>
        <div class="d-flex gap-2">
            <button id="btnGenererAjax" class="btn btn-warning rounded-pill px-4 shadow-sm fw-bold">
                <i class="bi bi-magic me-1"></i> Générer Automatiquement
            </button>
            <button onclick="window.print()" class="btn btn-dark rounded-pill px-4">
                <i class="bi bi-printer"></i> PDF
            </button>
        </div>
    </div>

    <div class="card mb-4 border-0 shadow-sm bg-light">
        <div class="card-body">
            <form method="get" class="row align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-bold text-secondary small">GROUPE :</label>
                    <select name="groupeId" class="form-select border-primary" onchange="this.form.submit()" asp-items="ViewBag.Groupes">
                        <option value="">-- Tous les groupes --</option>
                    </select>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow border-0 overflow-hidden">
        <table class="table table-bordered mb-0 text-center">
            <thead class="bg-primary text-white">
                <tr>
                    <th style="width: 100px;">Heure</th>
                    @foreach (var j in joursNoms)
                    {
                        <th class="py-3">@j</th>
                    }
                </tr>
            </thead>
            <tbody>
                @for (int h = 8; h <= 18; h += 2)
                {
                    var hDebut = new TimeSpan(h, 0, 0);
                    <tr>
                        <td class="bg-light fw-bold text-primary align-middle">@h:00</td>
                        @for (int i = 1; i <= 5; i++)
                        {
                            <td class="p-2 cell-hover" style="height: 140px; width: 18%; vertical-align: top;">
                                @foreach (var item in Model.Where(c => (int)c.Jour == i && c.HeureDebut == hDebut))
                                {
                                    <div class="card border-0 border-start border-4 border-primary shadow-sm p-2 mb-2 text-start bg-white" style="font-size: 0.8rem;">
                                        <div class="fw-bold text-dark">@item.Titre</div>
                                        <div class="text-muted small">
                                            <i class="bi bi-person"></i> @item.Utilisateur?.Nom <br />
                                            <i class="bi bi-geo-alt text-danger"></i> @item.Salle?.Nom
                                        </div>
                                    </div>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .cell-hover:hover {
        background-color: #f8f9fa !important;
    }

    .card {
        transition: 0.2s;
    }

    @@media print {
        .btn, form, #statusMessage {
            display: none !important;
        }
    }
</style>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            $("#btnGenererAjax").click(function () {
                if (!confirm("Réorganiser le planning selon les présences des profs ?")) return;

                var btn = $(this);
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Calcul...');
                $("#statusMessage").html("Traitement en cours...");

                $.ajax({
                    url: '@Url.Action("GenererPlanningAleatoire", "Planning")',
                    type: 'POST',
                    success: function (res) {
                        if (res.success) {
                            $("#statusMessage").addClass("text-success").html(res.message);
                            setTimeout(function() { location.reload(); }, 1000);
                        } else {
                            alert(res.message);
                            btn.prop('disabled', false).text("Générer Automatiquement");
                        }
                    }
                });
            });
        });
    </script>
}