@model IEnumerable<GestionHoraire.Models.Cours>

@{
    ViewData["Title"] = "Gestion des Affectations";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h2 class="text-dark fw-bold m-0">
                <i class="bi bi-journal-check text-danger me-2"></i>Affectations des Cours
            </h2>
            <p class="text-muted mb-0">Gérez les cours du département et assignez les professeurs.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="CreerCours" class="btn btn-success rounded-pill px-4 shadow-sm">
                <i class="bi bi-plus-circle me-1"></i> Nouveau Cours
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-light rounded-3 border border-dashed">
            <i class="bi bi-book display-1 text-muted"></i>
            <p class="fs-4 text-secondary mt-3">Aucun cours n'est actuellement enregistré pour votre département.</p>
            <a asp-action="CreerCours" class="btn btn-primary mt-2">Créer le premier cours</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4 py-3">Titre du Cours</th>
                            <th>Groupe</th>
                            <th>Professeur Assigné</th>
                            <th class="text-center">Statut</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var courseGroup in Model.GroupBy(c => new { 
                            Titre = (c.Titre ?? "").Trim().ToLower(), 
                            c.UtilisateurId, 
                            ProfesseurIds = (c.ProfesseurIds ?? "").Trim().TrimEnd(','), 
                            c.SalleId 
                        }))
                        {
                            var firstItem = courseGroup.First();
                            <tr>
                                <td class="ps-4">
                                    <span class="fw-bold fs-5 text-dark">@firstItem.Titre</span>
                                </td>
                                <td>
                                    @foreach (var item in courseGroup)
                                    {
                                        var gids = string.IsNullOrEmpty(item.GroupeIds) ? new string[0] : item.GroupeIds.Split(',');
                                        var allGrps = (List<GestionHoraire.Models.Groupe>)ViewBag.AllGroupes;
                                        
                                        foreach (var gid in gids)
                                        {
                                            var gn = allGrps?.FirstOrDefault(g => g.Id.ToString() == gid.Trim())?.Nom ?? "Inconnu";
                                            <span class="badge bg-info-subtle text-info border border-info px-2 mb-1 d-inline-block">
                                                <i class="bi bi-people-fill me-1"></i> @gn
                                            </span>
                                        }
                                    }
                                    @if (!courseGroup.Any(c => !string.IsNullOrEmpty(c.GroupeIds)))
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border px-2">Aucun groupe</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var pids = string.IsNullOrEmpty(firstItem.ProfesseurIds) 
                                                   ? (firstItem.UtilisateurId.HasValue ? new string[] { firstItem.UtilisateurId.Value.ToString() } : new string[0])
                                                   : firstItem.ProfesseurIds.Split(',');
                                        var allUsers = (List<GestionHoraire.Models.Utilisateur>)ViewBag.AllUsers;
                                    }
                                    @if (!pids.Any())
                                    {
                                        <span class="text-muted small italic">Aucun professeur</span>
                                    }
                                    else
                                    {
                                        foreach (var pid in pids)
                                        {
                                            var prof = allUsers?.FirstOrDefault(u => u.Id.ToString() == pid.Trim());
                                            if (prof != null)
                                            {
                                                <div class="d-flex align-items-center mb-1">
                                                    <div class="bg-primary-subtle p-1 rounded-circle me-2" style="font-size: 0.8rem;">
                                                        <i class="bi bi-person-fill text-primary"></i>
                                                    </div>
                                                    <span class="fw-medium small">@prof.Nom</span>
                                                    <a asp-controller="Disponibilite" asp-action="Index" 
                                                       asp-route-professeurId="@prof.Id" 
                                                       asp-route-returnUrl="/Affectations/Index" 
                                                       class="text-info ms-2" title="Gérer disponibilités">
                                                        <i class="bi bi-calendar-event"></i>
                                                    </a>
                                                </div>
                                            }
                                        }
                                    }
                                </td>
                                <td class="text-center">
                                    @if (firstItem.UtilisateurId != null || !string.IsNullOrEmpty(firstItem.ProfesseurIds))
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success px-3">Assigné</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning px-3">En attente</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm rounded">
                                        <a asp-action="EditerAffectation" asp-route-id="@firstItem.Id"
                                           class="btn btn-sm btn-white border btn-dynamic" title="Modifier le professeur">
                                            <i class="bi bi-person-plus text-primary"></i> Affecter
                                        </a>

                                        <form asp-controller="Affectations" asp-action="SupprimerCours" asp-route-id="@firstItem.Id"
                                              method="post" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer tous les records liés à ce cours (@firstItem.Titre) pour ces groupes ?');"
                                              style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-white border border-start-0 btn-dynamic" title="Supprimer">
                                                <i class="bi bi-trash text-danger"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-3 text-muted small">
            <i class="bi bi-info-circle me-1"></i> Cliquez sur "Affecter" pour choisir un professeur parmi votre équipe pédagogique.
        </div>
    }
</div>

<style>
    .table thead th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
    }

    .btn-white {
        background: white;
    }

        .btn-white:hover {
            background: #f8f9fa;
        }

    .btn-dynamic {
        transition: all 0.3s ease;
    }

    .btn-dynamic:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.15) !important;
    }

    .btn-dynamic:active {
        transform: translateY(0);
    }
</style>