@model GestionHoraire.Models.Groupe

@{
    ViewData["Title"] = "Modifier le Groupe";
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    body {
        background: #f8fafc;
        font-family: 'Outfit', sans-serif;
    }

    .premium-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(12px);
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
    }

    .card-header-gradient {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        color: white;
        border-radius: 24px 24px 0 0 !important;
        padding: 1.5rem;
    }

    .form-control, .form-select {
        border-radius: 12px;
        padding: 12px 20px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
    }

    .form-control:focus, .form-select:focus {
        box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        border-color: #4f46e5;
    }

    .btn-premium {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px;
        font-weight: 600;
        transition: all 0.3s;
    }

    .btn-premium:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(79, 70, 229, 0.2);
        color: white;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="premium-card overflow-hidden">
                <div class="card-header-gradient text-center">
                    <h3 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Modifier le Groupe</h3>
                </div>
                <div class="card-body p-4 p-lg-5">
                    <form asp-action="Modifier" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="DepartementId" />

                        <div class="mb-4">
                            <label asp-for="Nom" class="form-label fw-bold text-muted small text-uppercase">Nom du Groupe</label>
                            <input asp-for="Nom" class="form-control" placeholder="Ex: Informatique 1A" />
                            <span asp-validation-for="Nom" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Niveau" class="form-label fw-bold text-muted small text-uppercase">Niveau</label>
                            <select asp-for="Niveau" class="form-select">
                                <option value="Licence 1">Licence 1</option>
                                <option value="Licence 2">Licence 2</option>
                                <option value="Licence 3">Licence 3</option>
                                <option value="Master 1">Master 1</option>
                                <option value="Master 2">Master 2</option>
                            </select>
                            <span asp-validation-for="Niveau" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Effectif" class="form-label fw-bold text-muted small text-uppercase">Effectif (Max 40)</label>
                            <input asp-for="Effectif" type="number" class="form-control" />
                            <span asp-validation-for="Effectif" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-3 mt-5">
                            <button type="submit" class="btn btn-premium">Enregistrer les modifications</button>
                            <a asp-action="Index" class="btn btn-light rounded-3 py-2 fw-600">Annuler</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}