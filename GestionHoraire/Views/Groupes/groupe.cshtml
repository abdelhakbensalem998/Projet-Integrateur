@model IEnumerable<GestionHoraire.Models.Groupe>
@using Microsoft.AspNetCore.Http

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

@{
    ViewData["Title"] = "Gestion des Groupes";
    // Récupération de l'ID du département actuellement filtré depuis l'URL (si présent)
    string selectedDeptId = Context.Request.Query["idDept"];
}

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h1 class="h2 fw-bold text-dark m-0">Gestion des Groupes</h1>
            <p class="text-muted m-0 mt-1">
                <i class="bi bi-shield-lock-fill me-1 text-warning"></i>
                Mode : <strong>@(Context.Session.GetString("UserRole") == "Administrateur" ? "Administration Globale" : "Départemental")</strong>
            </p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Responsable" asp-action="Index" class="btn btn-outline-secondary shadow-sm rounded-pill px-3 fw-bold transition-hover">
                <i class="bi bi-house-door me-1"></i> Tableau de bord
            </a>
            <a asp-controller="Groupes" asp-action="Ajouter" class="btn btn-warning shadow-sm rounded-pill px-4 fw-bold text-white transition-hover">
                <i class="bi bi-plus-lg me-1"></i> Nouveau Groupe
            </a>
        </div>
    </div>

    @* --- ZONE DE FILTRE --- *@
    @if (Context.Session.GetString("UserRole") == "Administrateur" && ViewBag.Departements != null)
    {
        <div class="card shadow-sm border-0 mb-5 bg-light" style="border-radius: 15px;">
            <div class="card-body p-4">
                <form method="get" asp-controller="Groupes" asp-action="Index" class="row g-3 align-items-end">
                    <div class="col-md-6 col-lg-5">
                        <label for="idDept" class="form-label fw-bold text-secondary mb-2">
                            <i class="bi bi-filter-circle me-1"></i> Filtrer par Département
                        </label>
                        <select name="idDept" id="idDept" class="form-select form-select-lg border-0 shadow-sm" style="border-radius: 10px;" onchange="this.form.submit()">
                            <option value="">-- Tous les départements --</option>
                            @foreach (var dept in (SelectList)ViewBag.Departements)
                            {
                                <option value="@dept.Value" selected="@(dept.Value == selectedDeptId)">@dept.Text</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 col-lg-7 d-flex gap-2 justify-content-md-end pt-2">
                        @if (!string.IsNullOrEmpty(selectedDeptId))
                        {
                            <a asp-controller="Groupes" asp-action="Index" class="btn btn-lg btn-outline-secondary rounded-pill px-4 transition-hover">
                                <i class="bi bi-x-circle me-1"></i> Réinitialiser
                            </a>
                        }
                    </div>
                </form>
            </div>
        </div>
    }
    @* --- FIN ZONE DE FILTRE --- *@

    @if (Model != null && Model.Any())
    {
        // On groupe les données par département pour l'affichage
        var groupesParDept = Model.GroupBy(g => g.Departement?.Nom ?? "Sans Département");

        foreach (var groupeDept in groupesParDept)
        {
            <div class="mb-5">
                <h4 class="mt-2 mb-4 text-secondary border-start border-warning border-4 ps-3 fw-bold align-items-center d-flex">
                    <i class="bi bi-building me-2 text-warning opacity-75"></i> @groupeDept.Key
                </h4>

                <div class="row g-4">
                    @foreach (var item in groupeDept)
                    {
                        <div class="col-sm-6 col-md-4 col-lg-3">
                            <div class="card h-100 border-0 shadow-sm group-card position-relative overflow-hidden" style="border-radius: 18px; transition: all 0.3s ease;">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <h5 class="card-title fw-bold mb-0 text-truncate text-dark" title="@item.Nom">@item.Nom</h5>
                                    </div>

                                    <div class="mb-3 d-flex flex-column gap-1">
                                        <div class="small text-muted d-flex align-items-center">
                                            <i class="bi bi-layers me-2 text-warning opacity-75"></i>
                                            <strong>Niveau :</strong> <span class="ms-1">@item.Niveau</span>
                                        </div>
                                        <div class="small text-muted d-flex align-items-center">
                                            <i class="bi bi-person-badge me-2 text-warning opacity-75"></i>
                                            <strong>Effectif :</strong> <span class="ms-1">@item.Effectif étudiants</span>
                                        </div>
                                    </div>

                                    <div class="progress mb-2 bg-light" style="height: 6px; border-radius: 3px;">
                                        @{
                                            // Calcul du pourcentage basé sur une capacité arbitraire de 40 pour l'exemple
                                            var progression = (item.Effectif * 100) / 40;
                                            if (progression > 100) progression = 100;
                                        }
                                        <div class="progress-bar bg-warning rounded-pill" role="progressbar" style="width: @progression%" aria-valuenow="@progression" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                </div>

                                <div class="card-actions-overlay d-flex justify-content-center align-items-center gap-2">
                                    <a asp-controller="Groupes" asp-action="Modifier" asp-route-id="@item.Id"
                                       class="btn btn-primary rounded-pill px-3 py-2 fw-bold shadow-sm transition-hover" title="Modifier le groupe">
                                        <i class="bi bi-pencil-square me-1"></i> Modifier
                                    </a>

                                    <form asp-controller="Groupes" asp-action="Supprimer" method="post"
                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer définitivement le groupe @item.Nom ?');" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-danger rounded-pill px-3 py-2 fw-bold shadow-sm transition-hover" title="Supprimer le groupe">
                                            <i class="bi bi-trash3 me-1"></i> Supprimer
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-5 bg-white shadow-sm rounded-4 mt-5 border">
            <i class="bi bi-search display-1 text-muted opacity-25"></i>
            <p class="mt-4 fs-5 text-muted fw-light">Aucun groupe trouvé pour les critères de sélection actuels.</p>
            @if (!string.IsNullOrEmpty(selectedDeptId))
            {
                <a asp-controller="Groupes" asp-action="Index" class="btn btn-outline-secondary mt-3 rounded-pill transition-hover">
                    <i class="bi bi-arrow-left me-1"></i> Voir tous les groupes
                </a>
            }
        </div>
    }
</div>

@* --- STYLES CSS PERSONNALISÉS --- *@
<style>
    /* Style général des cartes de groupe */
    .group-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 1rem 2.5rem rgba(0,0,0,0.12) !important;
    }

    /* Style de l'overlay d'actions (masqué par défaut) */
    .card-actions-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(255, 255, 255, 0.96); /* Fond blanc semi-transparent */
        opacity: 0; /* Masqué */
        visibility: hidden;
        transition: all 0.35s ease-in-out;
        z-index: 10;
        backdrop-filter: blur(2px); /* Léger flou d'arrière-plan */
    }

    /* Affichage de l'overlay au survol de la carte */
    .group-card:hover .card-actions-overlay {
        opacity: 1; /* Affiché */
        visibility: visible;
    }

    /* Ajustement des styles des boutons dans l'overlay */
    .card-actions-overlay .btn {
        font-size: 0.85rem;
        letter-spacing: 0.3px;
    }

    /* Effets de transition génériques */
    .transition-hover {
        transition: all 0.2s ease-in-out;
    }
    .transition-hover:hover {
        transform: scale(1.03);
    }

    /* Style du select du filtre */
    .form-select-lg:focus {
        border-color: #ffc107;
        box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25);
    }
</style>