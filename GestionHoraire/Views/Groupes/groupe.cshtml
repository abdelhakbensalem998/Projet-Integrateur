@model IEnumerable<GestionHoraire.Models.Groupe>

@{
    ViewData["Title"] = "Gestion des Groupes";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    .hover-card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
        border-radius: 12px;
        overflow: hidden;
    }

        .hover-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.1) !important;
        }

    .badge-dept {
        background-color: rgba(255, 193, 7, 0.1);
        color: #856404;
        border: 1px solid rgba(255, 193, 7, 0.3);
    }

    .btn-circle {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
    }
</style>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h2 class="fw-bold text-dark m-0">
                <i class="bi bi-people-fill text-warning me-2"></i>Gestion des Groupes
            </h2>
            <p class="text-muted m-0">
                Département : <strong>@(Model.FirstOrDefault()?.Departement?.Nom ?? "Chargement...")</strong>
            </p>
        </div>
        <a asp-controller="Groupes" asp-action="Ajouter" class="btn btn-warning shadow-sm rounded-pill px-4 fw-bold text-white">
            <i class="bi bi-plus-lg me-1"></i> Nouveau Groupe
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm hover-card">
                        <div class="card-header bg-warning p-1 border-0"></div>

                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="fw-bold m-0 text-truncate" title="@item.Nom">@item.Nom</h5>
                            </div>

                            <div class="mb-3">
                                <span class="badge badge-dept rounded-pill px-3">
                                    <i class="bi bi-mortarboard-fill me-1"></i>
                                    @(item.Departement?.Nom ?? "N/A")
                                </span>
                            </div>

                            <div class="d-flex flex-column gap-2 mb-3">
                                <div class="small text-muted">
                                    <i class="bi bi-layers me-2 text-primary"></i><strong>Niveau :</strong> @item.Niveau
                                </div>
                                <div class="small text-muted">
                                    <i class="bi bi-person-badge me-2 text-primary"></i><strong>Effectif :</strong> @item.Effectif étudiants
                                </div>
                            </div>

                            <div class="progress" style="height: 6px;">
                                @{
                                    // Calcul du pourcentage basé sur une capacité de 40
                                    var percent = (item.Effectif * 100) / 40;
                                    if (percent > 100) percent = 100;
                                }
                                <div class="progress-bar bg-warning" role="progressbar" style="width: @percent%"></div>
                            </div>
                        </div>

                        <div class="card-footer bg-light border-0 d-flex justify-content-center gap-3 pb-3">
                            <a asp-controller="Groupes" asp-action="Modifier" asp-route-id="@item.Id"
                               class="btn btn-warning btn-circle shadow-sm" title="Modifier">
                                <i class="bi bi-pencil-fill text-white"></i>
                            </a>

                            <form asp-controller="Groupes" asp-action="Supprimer" method="post"
                                  onsubmit="return confirm('Supprimer le groupe @item.Nom ?');" style="display:inline;">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-danger btn-circle shadow-sm" title="Supprimer">
                                    <i class="bi bi-trash-fill text-white"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-light rounded-4 border">
            <i class="bi bi-people display-1 text-muted opacity-25"></i>
            <p class="mt-3 fs-5 text-muted">Aucun groupe trouvé pour votre département.</p>
            <a asp-controller="Groupes" asp-action="Ajouter" class="btn btn-warning mt-2 text-white">Créer le premier groupe</a>
        </div>
    }

    <div class="mt-5 mb-4">
        <a asp-controller="Responsable" asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">
            <i class="bi bi-arrow-left me-2"></i>Retour au Dashboard
        </a>
    </div>
</div>